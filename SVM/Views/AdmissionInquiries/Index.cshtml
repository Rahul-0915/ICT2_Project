@model IEnumerable<SVM.Models.AdmissionInquiry>

@{
    ViewData["Title"] = "Admission Inquiries";
}

<link rel="stylesheet" href="~/css/AdminSide_Css/AdmissionInquiry.css" asp-append-version="true" />
<div class="admin-wrapper">

   

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- TABLE -->

    <div class="table-card">
        <!-- Add this before the table-card div -->
        <div class="print-header" style="margin-bottom: 15px; text-align: right;">
            <button onclick="printTableData()" class="btn-print" style="padding: 8px 16px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                Print Table Data
            </button>
        </div>
        <table class="admin-table">

            <thead>
                <tr>
                    
                    <th>Student Name</th>
                    <th>Parent Name</th>
                    <th>Message</th>
                    <th>Phone</th>
                    <th>Class</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="@(item.IsSeen == true ? "" : "unseen-row")">

                        
                        <td>@item.StudentName</td>
                        <td>@item.ParentName</td>
                        <td>@item.Message</td>
                        <td>@item.Phone</td>
                        <td>@item.ClassName</td>
                        

                        <td>
                            @(item.InquiryDate?.ToString("dd-MM-yyyy"))
                        </td>

                        <td>
                            @if (item.IsAttended == true)
                            {
                                <span class="badge success">Attended</span>
                            }
                            else
                            {
                                <span class="badge pending">Pending</span>
                            }
                        </td>

                        <td class="actions">

                        

                            @if (item.IsAttended != true)
                            {
                                <form asp-action="Attend" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.InquiryId" />
                                    <input type="hidden" name="replyMessage" value="Attended by admin" />
                                    <button class="btn attend">Attend</button>
                                </form>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- NOTIFICATION JS -->
<script>
    async function loadUnseenCount() {
        try {
            const res = await fetch('/AdmissionInquiries/GetUnseenCount');
            const data = await res.json();
            document.getElementById("notifyCount").innerText = data;
        } catch (e) {
            console.log(e);
        }
    }

    loadUnseenCount();
    setInterval(loadUnseenCount, 10000);

    async function loadUnseenCount() {
        try {
            const res = await fetch('/AdmissionInquiries/GetUnseenCount');
            const data = await res.json();
            document.getElementById("notifyCount").innerText = data;
        } catch (e) {
            console.log(e);
        }
    }

    loadUnseenCount();
    setInterval(loadUnseenCount, 10000);

    // Print function
    function printTableData() {
        // Get table
        var table = document.querySelector('.admin-table');
        var cloneTable = table.cloneNode(true);

        // Remove Action column (last column)
        var allRows = cloneTable.querySelectorAll('tr');
        allRows.forEach(function (row) {
            var lastCell = row.querySelector('td:last-child, th:last-child');
            if (lastCell) lastCell.remove();
        });

        // Create print window
        var printWin = window.open('', '_blank');

        // HTML for print
        printWin.document.write(`
                <html>
                <head>
                    <title>Admission Inquiries</title>
                    <style>
                        body { font-family: Arial; margin: 20px; }
                        h2 { text-align: center; }
                        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
                        th, td { border: 1px solid #000; padding: 8px; text-align: left; }
                        th { background: #f2f2f2; }
                        .success { color: green; font-weight: bold; }
                        .pending { color: orange; font-weight: bold; }
                        .date { text-align: center; margin-bottom: 20px; }
                    </style>
                </head>
                <body>
                    <h2>Admission Inquiries Report</h2>
                    <div class="date">Date: ${new Date().toLocaleString()}</div>
                    ${cloneTable.outerHTML}
                    <script>
                        window.onload = function() {
                            window.print();
                            window.close();
                        };
                    <\/script>
                </body>
                </html>
            `);

        printWin.document.close();
    }


</script>