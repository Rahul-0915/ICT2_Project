@model List<SVM.Controllers.FeePaymentReportVM>

@{
    ViewData["Title"] = "Fee Collection Report";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fee Collection Report</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #f5f7fa;
            padding: 24px;
        }

        .page-title {
            margin-bottom: 24px;
        }

            .page-title h1 {
                font-size: 24px;
                color: #1e293b;
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .page-title p {
                color: #64748b;
                font-size: 14px;
                margin-top: 5px;
            }

        .filter-bar {
            background: white;
            border-radius: 16px;
            padding: 20px 24px;
            margin-bottom: 24px;
            border: 1px solid #e5e7eb;
        }

        .filter-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: flex-end;
            margin-bottom: 16px;
        }

        .filter-group {
            flex: 1;
            min-width: 150px;
        }

            .filter-group label {
                display: block;
                font-size: 12px;
                font-weight: 600;
                color: #4b5563;
                margin-bottom: 6px;
                text-transform: uppercase;
            }

            .filter-group select, .filter-group input {
                width: 100%;
                padding: 10px 12px;
                border: 1px solid #d1d5db;
                border-radius: 10px;
                font-size: 14px;
                font-family: inherit;
            }

                .filter-group select:focus, .filter-group input:focus {
                    outline: none;
                    border-color: #3b82f6;
                }

        .search-btn, .reset-btn, .excel-btn {
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            font-family: inherit;
        }

        .search-btn {
            background: #3b82f6;
            color: white;
        }

        .reset-btn {
            background: #6b7280;
            color: white;
        }

        .excel-btn {
            background: #10b981;
            color: white;
        }

            .search-btn:hover, .reset-btn:hover, .excel-btn:hover {
                transform: translateY(-1px);
            }

        /* Loading Overlay */
        .loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }

        .loading-content {
            background: white;
            padding: 30px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3b82f6;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .summary-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #e5e7eb;
            text-align: center;
        }

            .summary-card h3 {
                font-size: 13px;
                color: #64748b;
                text-transform: uppercase;
                margin-bottom: 10px;
            }

            .summary-card .amount {
                font-size: 28px;
                font-weight: 800;
            }

            .summary-card.cash .amount {
                color: #059669;
            }

            .summary-card.online .amount {
                color: #3b82f6;
            }

            .summary-card.total .amount {
                color: #8b5cf6;
            }

        .table-wrapper {
            background: white;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #e5e7eb;
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

            .data-table th {
                background: #f8fafc;
                padding: 14px;
                text-align: left;
                font-weight: 600;
                font-size: 13px;
                border-bottom: 2px solid #e5e7eb;
            }

            .data-table td {
                padding: 12px 14px;
                border-bottom: 1px solid #f1f5f9;
                font-size: 13px;
            }

            .data-table tr:hover {
                background: #f8fafc;
            }

        .badge-cash {
            background: #d1fae5;
            color: #059669;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }

        .badge-online {
            background: #e0e7ff;
            color: #4338ca;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }

        .total-box {
            margin-top: 20px;
            padding: 15px 20px;
            background: #f0fdf4;
            border-radius: 12px;
            display: flex;
            justify-content: flex-end;
            gap: 30px;
            border: 1px solid #dcfce7;
        }

        .total-item {
            font-size: 16px;
        }

            .total-item strong {
                font-size: 20px;
                color: #059669;
            }

        .no-data {
            text-align: center;
            padding: 50px;
            color: #6b7280;
            background: white;
            border-radius: 16px;
        }

        @@media (max-width: 768px) {
            body {
                padding: 16px;
            }

            .filter-row {
                flex-direction: column;
            }

            .filter-group {
                width: 100%;
            }

            .summary-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-content">
            <div class="spinner"></div>
            <p>Loading report data...</p>
        </div>
    </div>

    

    <div class="filter-bar">
        <div class="filter-row">
            <div class="filter-group">
                <label><i class="fa-regular fa-calendar"></i> SESSION <span style="color:red;">*</span></label>
                <select id="sessionFilter">
                    <option value="">Select Session</option>
                    @if (ViewBag.AllSessions != null)
                    {
                        foreach (var s in ViewBag.AllSessions)
                        {
                            <option value="@s.SessionId" selected="@(ViewBag.SelectedSessionId == s.SessionId ? "selected" : null)">
                                @s.SessionName
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label><i class="fa-regular fa-hashtag"></i> TRANSACTION ID</label>
                <input type="text" id="transactionSearch" placeholder="Search by Transaction ID" value="@ViewBag.SearchTransactionId">
            </div>
           
        </div>

        <div class="filter-row">
           

            <div class="filter-group">
                <label><i class="fa-regular fa-credit-card"></i> PAYMENT MODE</label>
                <select id="paymentModeFilter">
                    @if (ViewBag.PaymentModes != null)
                    {
                        foreach (var mode in ViewBag.PaymentModes)
                        {
                            <option value="@mode.Value" selected="@(ViewBag.SelectedPaymentMode == mode.Value ? "selected" : null)">
                                @mode.Text
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label><i class="fa-regular fa-calendar"></i> FROM DATE</label>
                <input type="date" id="fromDate" value="@ViewBag.FromDate">
            </div>

            <div class="filter-group">
                <label><i class="fa-regular fa-calendar"></i> TO DATE</label>
                <input type="date" id="toDate" value="@ViewBag.ToDate">
            </div>

            <div>
                <button class="search-btn" onclick="searchReports()">
                    <i class="fa-solid fa-magnifying-glass"></i> Generate Report
                </button>
                <button class="reset-btn" onclick="resetFilters()">
                    <i class="fa-solid fa-rotate-right"></i> Reset
                </button>
                <button class="excel-btn" onclick="downloadExcel()">
                    <i class="fa-solid fa-file-excel"></i> Excel
                </button>
            </div>
        </div>
    </div>

    <div id="reportContent">
        @if (Model != null && Model.Any())
        {
            var cashTotal = Model.Where(p => p.PaymentMode == "Cash").Sum(p => p.AmountPaid);
            var onlineTotal = Model.Where(p => p.PaymentMode == "Razorpay").Sum(p => p.AmountPaid);
            var grandTotal = cashTotal + onlineTotal;

            <div class="summary-cards">
                <div class="summary-card cash">
                    <h3><i class="fa-solid fa-money-bill-wave"></i> Cash Collection</h3>
                    <div class="amount">₹@cashTotal.ToString("N2")</div>
                </div>
                <div class="summary-card online">
                    <h3><i class="fa-solid fa-credit-card"></i> Online Collection</h3>
                    <div class="amount">₹@onlineTotal.ToString("N2")</div>
                </div>
                <div class="summary-card total">
                    <h3><i class="fa-solid fa-chart-simple"></i> Grand Total</h3>
                    <div class="amount">₹@grandTotal.ToString("N2")</div>
                </div>
                <div class="summary-card">
                    <h3><i class="fa-regular fa-receipt"></i> Total Transactions</h3>
                    <div class="amount">@Model.Count</div>
                </div>
            </div>

            <div class="table-wrapper">
                <table id="paymentsTable" class="data-table">
                    <thead>
                        <tr>
                            <th>Sr. No.</th>
                            <th>Student Name</th>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Amount (₹)</th>
                            <th>Payment Mode</th>
                            <th>Transaction ID</th>
                            <th>Payment Date</th>
                    </thead>
                    <tbody>
                        @{
                            int sr = 1;
                            foreach (var payment in Model)
                            {
                                string paymentDateFormatted = payment.PaymentDate?.ToString("dd-MM-yyyy HH:mm:ss") ?? "-";

                                <tr>
                                    <td>@sr</td>
                                    <td>@payment.StudentName</td>
                                    <td>@payment.ClassName</td>
                                    <td>@payment.SectionName</td>
                                    <td>₹@payment.AmountPaid.ToString("N2")</td>
                                    <td>
                                        <span class="@(payment.PaymentMode == "Cash" ? "badge-cash" : "badge-online")">
                                            @payment.PaymentMode
                                        </span>
                                    </td>
                                    <td>@payment.TransactionId</td>
                                    <td>@paymentDateFormatted</td>
                                </tr>
                                sr++;
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="total-box">
                <div class="total-item">Total Records: <strong>@Model.Count</strong></div>
                <div class="total-item">Total Collection: <strong>₹@grandTotal.ToString("N2")</strong></div>
            </div>
        }
        else if (ViewBag.SelectedSessionId != null)
        {
            <div class="no-data">
                <i class="fa-regular fa-receipt" style="font-size:48px; color:#cbd5e1; margin-bottom:15px; display:block;"></i>
                <p>No payment records found for the selected criteria</p>
            </div>
        }
        else
        {
            <div class="no-data">
                <i class="fa-regular fa-calendar" style="font-size:48px; color:#cbd5e1; margin-bottom:15px; display:block;"></i>
                <p>Please select a session and click "Generate Report"</p>
            </div>
        }
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script>
        let dataTable;
        let searchTimeout;

        $(document).ready(function () {
            initializeDataTable();

            // Load classes when medium changes
            $("#mediumFilter").on('change', function () {
                let sessionId = $("#sessionFilter").val();
                let medium = $(this).val();

                $("#classFilter").html('<option value="">All Classes</option>');
                $("#sectionFilter").html('<option value="">All Sections</option>');

                if (sessionId && medium) {
                    $.ajax({
                        url: '@Url.Action("GetClassesByMedium", "FeeReports")',
                        type: 'GET',
                        data: { medium: medium, sessionId: sessionId },
                        success: function (data) {
                            let options = '<option value="">All Classes</option>';
                            $.each(data, function (i, item) {
                                options += `<option value="${item.value}">${item.text}</option>`;
                            });
                            $("#classFilter").html(options);
                        }
                    });
                }
            });

            // Load sections when class changes
            $("#classFilter").on('change', function () {
                let classId = $(this).val();
                $("#sectionFilter").html('<option value="">All Sections</option>');
                if (classId) {
                    $.ajax({
                        url: '@Url.Action("GetSectionsByClass", "FeeReports")',
                        type: 'GET',
                        data: { classId: classId },
                        success: function (data) {
                            let options = '<option value="">All Sections</option>';
                            $.each(data, function (i, item) {
                                options += `<option value="${item.value}">${item.text}</option>`;
                            });
                            $("#sectionFilter").html(options);
                        }
                    });
                }
            });

            // Auto search on filter change (with debounce)
            $("#sessionFilter, #mediumFilter, #classFilter, #sectionFilter, #paymentModeFilter, #fromDate, #toDate").on('change', function () {
                if ($("#sessionFilter").val()) {
                    searchReports();
                }
            });

            // Debounced search for transaction ID
            $("#transactionSearch").on('input', function () {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function () {
                    if ($("#sessionFilter").val()) {
                        searchReports();
                    }
                }, 500);
            });
        });

        function initializeDataTable() {
            if (dataTable) {
                dataTable.destroy();
                dataTable = null;
            }

            if ($('#paymentsTable').length && $('#paymentsTable tbody tr').length > 0) {
                dataTable = $('#paymentsTable').DataTable({
                    language: {
                        search: "Search:",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        infoEmpty: "No records found",
                        zeroRecords: "No matching records found",
                        paginate: {
                            first: "First",
                            last: "Last",
                            next: "Next",
                            previous: "Previous"
                        }
                    },
                    order: [[7, 'desc']],
                    pageLength: 25,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]]
                });
            }
        }

        // FIXED: AJAX search - NO PAGE BLINK
        function searchReports() {
            let sessionId = $("#sessionFilter").val();

            if (!sessionId) {
                alert("Please select Session");
                return;
            }

            let medium = $("#mediumFilter").val();
            let classId = $("#classFilter").val();
            let sectionId = $("#sectionFilter").val();
            let transactionId = $("#transactionSearch").val();
            let paymentMode = $("#paymentModeFilter").val();
            let fromDate = $("#fromDate").val();
            let toDate = $("#toDate").val();

            // Show loading overlay
            $("#loadingOverlay").fadeIn(200);

            // Build params
            let params = {
                sessionId: sessionId,
                medium: medium,
                classId: classId,
                sectionId: sectionId,
                searchTransactionId: transactionId,
                paymentMode: paymentMode,
                fromDate: fromDate,
                toDate: toDate
            };

            // AJAX call - no page reload
            $.ajax({
                url: '@Url.Action("SearchAjax", "FeeReports")',
                type: 'GET',
                data: params,
                success: function (response) {
                    $("#reportContent").html(response);
                    initializeDataTable();
                    updateUrlWithoutReload(params);
                },
                error: function (xhr, status, error) {
                    console.error("Search error:", error);
                    $("#reportContent").html(`
                                <div class="no-data">
                                    <i class="fa-solid fa-circle-exclamation" style="font-size:48px; color:#ef4444; margin-bottom:15px; display:block;"></i>
                                    <p>Error loading report. Please try again.</p>
                                </div>
                            `);
                },
                complete: function () {
                    $("#loadingOverlay").fadeOut(200);
                }
            });
        }

        // Update URL without page reload
        function updateUrlWithoutReload(params) {
            let urlParams = new URLSearchParams();

            if (params.sessionId) urlParams.set('sessionId', params.sessionId);
            if (params.medium && params.medium !== '') urlParams.set('medium', params.medium);
            if (params.classId && params.classId !== '') urlParams.set('classId', params.classId);
            if (params.sectionId && params.sectionId !== '') urlParams.set('sectionId', params.sectionId);
            if (params.searchTransactionId) urlParams.set('searchTransactionId', params.searchTransactionId);
            if (params.paymentMode && params.paymentMode !== '') urlParams.set('paymentMode', params.paymentMode);
            if (params.fromDate) urlParams.set('fromDate', params.fromDate);
            if (params.toDate) urlParams.set('toDate', params.toDate);

            let newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
            window.history.pushState({ path: newUrl }, '', newUrl);
        }

        function resetFilters() {
            window.location.href = '@Url.Action("Index", "FeeReports")';
        }

        // ========== EXCEL DOWNLOAD - UNCHANGED ==========
        function downloadExcel() {
            let rows = [];

            // Get filter values for header
            let sessionText = $("#sessionFilter option:selected").text() || "";
            let mediumText = $("#mediumFilter option:selected").val() || "All Medium";
            let classText = $("#classFilter option:selected").text() || "All Classes";
            let sectionText = $("#sectionFilter option:selected").text() || "All Sections";
            let paymentModeText = $("#paymentModeFilter option:selected").text() || "";
            let fromDateText = $("#fromDate").val() || "";
            let toDateText = $("#toDate").val() || "";

            // Format dates for display
            let formattedFromDate = fromDateText ? formatDateDMY(fromDateText) : "";
            let formattedToDate = toDateText ? formatDateDMY(toDateText) : "";

            // Header rows
            rows.push(["FEE COLLECTION REPORT"]);
            rows.push([`Generated on: ${formatDateTimeDMY(new Date())}`]);
            rows.push([]);
            rows.push([`Session: ${sessionText}`]);
            rows.push([`Medium: ${mediumText}`]);
            rows.push([`Class: ${classText}`]);
            rows.push([`Section: ${sectionText}`]);

            if (paymentModeText && paymentModeText !== "All Modes") {
                rows.push([`Payment Mode: ${paymentModeText}`]);
            }
            if (formattedFromDate) {
                rows.push([`From Date: ${formattedFromDate}`]);
            }
            if (formattedToDate) {
                rows.push([`To Date: ${formattedToDate}`]);
            }

            rows.push([]);
            rows.push([]);

            // Table Headers
            rows.push(["Sr. No.", "Student Name", "Class", "Section", "Amount (₹)", "Payment Mode", "Transaction ID", "Payment Date"]);

            // Table Data from visible table rows
            let totalAmount = 0;
            let srNo = 1;

            // Get data directly from table body (more reliable)
            $("#paymentsTable tbody tr").each(function () {
                let cols = $(this).find("td");
                if (cols.length >= 8) {
                    let amountText = $(cols[4]).text().replace('₹', '').replace(/,/g, '');
                    let amount = parseFloat(amountText) || 0;
                    let paymentDate = $(cols[7]).text().trim();

                    rows.push([
                        srNo++,
                        $(cols[1]).text().trim(),
                        $(cols[2]).text().trim(),
                        $(cols[3]).text().trim(),
                        amount,
                        $(cols[5]).text().trim(),
                        $(cols[6]).text().trim(),
                        paymentDate
                    ]);
                    totalAmount += amount;
                }
            });

            rows.push([]);
            rows.push(["GRAND TOTAL:", "", "", "", totalAmount.toFixed(2), "", "", ""]);

            // Cash/Online Summary
            let cashTotal = 0;
            let onlineTotal = 0;

            $("#paymentsTable tbody tr").each(function () {
                let cols = $(this).find("td");
                if (cols.length >= 8) {
                    let mode = $(cols[5]).text().trim();
                    let amountText = $(cols[4]).text().replace('₹', '').replace(/,/g, '');
                    let amount = parseFloat(amountText) || 0;
                    if (mode === "Cash") cashTotal += amount;
                    else if (mode === "Razorpay") onlineTotal += amount;
                }
            });

            rows.push([]);
            rows.push(["SUMMARY:"]);
            rows.push([`Cash Collection: ₹${cashTotal.toFixed(2)}`]);
            rows.push([`Online Collection: ₹${onlineTotal.toFixed(2)}`]);
            rows.push([`Total Records: ${srNo - 1}`]);

            rows.push([]);
            rows.push(["This is a system generated report. No signature required."]);

            // Create worksheet
            let ws = XLSX.utils.aoa_to_sheet(rows);

            // Set column widths
            ws['!cols'] = [
                { wch: 10 },
                { wch: 30 },
                { wch: 15 },
                { wch: 12 },
                { wch: 15 },
                { wch: 18 },
                { wch: 30 },
                { wch: 22 }
            ];

            // Merge title cells
            if (!ws['!merges']) ws['!merges'] = [];
            ws['!merges'].push({ s: { r: 0, c: 0 }, e: { r: 0, c: 7 } });
            ws['!merges'].push({ s: { r: 1, c: 0 }, e: { r: 1, c: 7 } });

            // Create workbook and save
            let wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Fee_Collection_Report");

            let fileName = `Fee_Collection_Report_${formatDateTimeForFile(new Date())}.xlsx`;
            XLSX.writeFile(wb, fileName);
        }

        // Helper function to format date as DD-MM-YYYY
        function formatDateDMY(dateString) {
            if (!dateString) return "";
            let parts = dateString.split('-');
            if (parts.length === 3) {
                return `${parts[2]}-${parts[1]}-${parts[0]}`;
            }
            return dateString;
        }

        // Helper function to format datetime as DD-MM-YYYY HH:MM:SS
        function formatDateTimeDMY(date) {
            let day = String(date.getDate()).padStart(2, '0');
            let month = String(date.getMonth() + 1).padStart(2, '0');
            let year = date.getFullYear();
            let hours = String(date.getHours()).padStart(2, '0');
            let minutes = String(date.getMinutes()).padStart(2, '0');
            let seconds = String(date.getSeconds()).padStart(2, '0');
            return `${day}-${month}-${year} ${hours}:${minutes}:${seconds}`;
        }

        // Helper function to format datetime for filename
        function formatDateTimeForFile(date) {
            let day = String(date.getDate()).padStart(2, '0');
            let month = String(date.getMonth() + 1).padStart(2, '0');
            let year = date.getFullYear();
            let hours = String(date.getHours()).padStart(2, '0');
            let minutes = String(date.getMinutes()).padStart(2, '0');
            let seconds = String(date.getSeconds()).padStart(2, '0');
            return `${year}${month}${day}_${hours}${minutes}${seconds}`;
        }
    </script>

</body>
</html>