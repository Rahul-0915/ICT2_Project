@model SVM.Models.Updates

@{
    ViewData["Title"] = "Edit Update";
}

<link rel="stylesheet" href="~/css/AdminSide_Css/Updates_Notice.css" asp-append-version="true" />

<div class="update-container">
    <div class="update-card">

        <h2 class="form-title">Edit Notice / Event</h2>
        <p class="form-subtitle">Update existing details</p>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="update-form">

            <div asp-validation-summary="ModelOnly" class="error-summary"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="FilePath" />

            <!-- TITLE -->
            <div class="form-group" style="width:92%">
                <label class="form-label">Title</label>
                <input asp-for="Title" class="form-input" />
                <span asp-validation-for="Title" class="form-error"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-input textarea" rows="3"></textarea>
                <span asp-validation-for="Description" class="form-error"></span>
            </div>

            <!-- CATEGORY -->
            <div class="form-group">
                <label class="form-label">Category</label>
                <select asp-for="Category" class="form-input select" asp-items="ViewBag.CategoryList"></select>
                <span asp-validation-for="Category" class="form-error"></span>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label class="form-label">Status</label>
                <select asp-for="Status" class="form-input select" asp-items="ViewBag.StatusList"></select>
                <span asp-validation-for="Status" class="form-error"></span>
            </div>

            <!-- CURRENT FILE -->
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="form-group">
                    <label class="form-label">Current File</label>

                    @if (Model.FilePath.EndsWith(".pdf"))
                    {
                        <a href="@Model.FilePath" target="_blank">📄 View PDF</a>
                    }
                    else
                    {
                        <img src="@Model.FilePath" style="max-width:120px;border-radius:10px;" />
                    }

                    <small class="form-hint">Leave empty if you don’t want to changes file</small>
                </div>
            }

            <!-- NEW FILE -->
            <div class="form-group">
                <label class="form-label">Replace File</label>

                <input type="file" id="UploadFile" name="UploadFile"
                       class="form-input file-input"
                       accept=".jpg,.jpeg,.png,.pdf"
                       onchange="previewFile(event)" />

                <span class="form-error"></span>

                <div id="imagePreviewContainer" class="preview-box">
                    <img id="imagePreview"/>
                    <span id="pdfLabel"></span>
                </div>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="submit-btn">Update</button>

        </form>

        <div class="back-link">
            <a asp-action="Index">← Back to List</a>
        </div>

    </div>
</div>

<script src="/js/AdminSide_Js/Updates_Notice.js"></script>