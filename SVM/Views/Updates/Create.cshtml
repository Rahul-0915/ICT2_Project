@model SVM.Models.Updates

@{
    ViewData["Title"] = "Create Update";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/css/Updates_Css/Updates_Notice.css" asp-append-version="true" />
    <title>Create Update</title>
  
</head>
<body>
    <div class="update-container">
        <div class="update-card">
            <h2 class="form-title">Notices & Events</h2>
            <p class="form-subtitle"> Add notices, and upload events images</p>

            <form asp-action="Create" method="post" enctype="multipart/form-data" class="update-form">
                <div asp-validation-summary="ModelOnly" class="error-summary"></div>

                <div class="form-group">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-input" placeholder="Enter title..." />
                    <span asp-validation-for="Title" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-input textarea" rows="3" placeholder="Write description..."></textarea>
                    <span asp-validation-for="Description" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select asp-for="Category" class="form-input select" asp-items="ViewBag.CategoryList"></select>
                    <span asp-validation-for="Category" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-input select" asp-items="ViewBag.StatusList"></select>
                    <span asp-validation-for="Status" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Upload File</label>
                    <input type="file" id="UploadFile" name="UploadFile" class="form-input file-input"
                           accept=".jpg,.jpeg,.png,.pdf"
                           onchange="previewFile(event)"/>

                    <small class="form-hint"></small>
                    <span asp-validation-for="FilePath" class="form-error"></span>

                    <div id="imagePreviewContainer" class="preview-box">
                        <img id="imagePreview"/>
                        <span id="pdfLabel"></span>
                    </div>
                </div>

                <input type="hidden" asp-for="CreatedAt" />

                <button type="submit" class="submit-btn">Publish</button>
            </form>

            <div class="back-link">
                <a asp-action="Index">← Back to List</a>
            </div>
        </div>
    </div>

    
        <script src="/js/Updates_Notice_js/Updates_Notice.js"></script>
    
</body>
</html>