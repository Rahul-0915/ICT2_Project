@model IEnumerable<SVM.Models.Updates>

@{
    ViewData["Title"] = "School Notices";
    Layout = "~/Views/Shared/UserLayout.cshtml";
    ViewBag.ShowPreloader = false;
}

@section PageCss {
    <link rel="stylesheet" href="@Url.Content("~/css/UserSide_Css/UserNotice.css")" />
}
   


<div class="notice-page">

    <div class="notice-header">

        <h2>Notice</h2>

        <p>
            Important announcements, circulars and latest school updates.
        </p>

    </div>

    @if (Model.Any())
    {
        <div class="notice-list">

            @foreach (var item in Model)
            {
                var extension = "";

                if (!string.IsNullOrEmpty(item.FilePath))
                {
                    extension = System.IO.Path
                    .GetExtension(item.FilePath)
                    .ToLower();
                }

                <div class="notice-card">

                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        // IMAGE FILES
                        if (extension == ".jpg" ||
                        extension == ".jpeg" ||
                        extension == ".png" ||
                        extension == ".gif" ||
                        extension == ".webp")
                        {
                            <a href="@item.FilePath"
                               target="_blank"
                               class="notice-image">

                                <img src="@item.FilePath"
                                     alt="@item.Title" />

                            </a>
                        }
                        else
                        {
                            // PDF / WORD / EXCEL
                            <div class="notice-file">

                                <div class="notice-file">
                                 
                                    <a href="@item.FilePath"
                                       target="_blank"
                                       class="view-file-btn">

                                        <i class="fa-solid fa-paperclip"></i>
                                        View Attachment

                                    </a>
                                </div>

                            </div>
                        }
                    }

                    <div class="notice-content">

                        <h2 class="notice-title">
                            @item.Title
                        </h2>

                        <div class="notice-date">
                            <i class="fa-regular fa-calendar"></i>
                            @item.CreatedAt.ToString("MMMM dd, yyyy")
                        </div>

                        <p class="notice-description">
                            @item.Description
                        </p>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="no-notice">
            No Notices Available
        </div>
    }

</div>
<script>
$(function () {

    let latestId = @(
        Model.Any()
        ? Model.Max(x => x.Id)
        : 0
    );

    let seenId = parseInt(localStorage.getItem("PublicNoticeSeen") || "0");

    if (latestId > seenId) {
        localStorage.setItem("PublicNoticeSeen", latestId);
    }

});
</script>