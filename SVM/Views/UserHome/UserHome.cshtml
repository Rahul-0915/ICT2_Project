@model IEnumerable<SVM.Models.Updates>

@{
    Layout = "~/Views/Shared/UserLayout.cshtml";
    ViewBag.Title = "Home";
    ViewBag.ShowPreloader = true;
}


<!-- SLIDER -->
<div class="slider">

    <div class="slides active">
        <img src="~/images/HomeSchoolModelPic.png">
    </div>

    <div class="slides">
        <img src="/images/svm gm poster.png">
    </div>

    <div class="slides">
        <img src="/images/svm em poster.png">
    </div>

    <div class="slider-text">
        <h1>Welcome to S.V.M School</h1>
        <p>SHARDA VIDYAMANDIR</p>
    </div>

</div>

<!-- INTRO -->
<section class="school-intro">
    <div class="intro-container">

        <div class="intro-img">

            <img src="~/images/SersvatiMata.jpg" alt="Saraswati Mata">
        </div>

        <div class="intro-text">
            <h2>Sharda Vidyamandir</h2>

            <p class="medium">
                Gujarati Medium & S.V.M English Medium School
            </p>

            <p class="highlight">
                "Shaping Bright Futures Through Quality Education, Strong Values,
                and Modern Learning. At Sharda Vidyamandir, we nurture young minds
                to grow with confidence, knowledge, and discipline, preparing them
                to succeed in a global world."
            </p>

            <p>
                Managed by <b>Shiv Shakti Education Trust</b>
            </p>

            <p class="trustee">
                Trustee: <b>Umakanat Sir</b>
            </p>
        </div>

    </div>
</section>

<!-- TIMING -->
<section class="timing">
    <h2>School Timing</h2>

    <div class="timing-container">

        <div class="timing-box">
            <h3>Gujarati Medium</h3>
            <p>Jr. KG to Std 8</p>
            <span>12:20 PM – 5:30 PM</span>
        </div>

        <div class="timing-box">
            <h3>Gujarati Medium</h3>
            <p>Std 9 to 12 Com</p>
            <span>7:20 AM – 12:10 PM</span>
        </div>

        <div class="timing-box">
            <h3>English Medium</h3>
            <p>Jr. KG to Std 12</p>
            <span>7:20 AM – 12:10 PM</span>
        </div>

    </div>
</section>

<!-- ADMISSION -->
<section class="admission">
    <div class="admission-content">
        <h2 class="blink">
            Admissions Open @ViewBag.ActiveSession
        </h2>

        <p>
            Sharda Vidyamandir Gujarati Medium & S.V.M English Medium School
        </p>

        <a href="#" class="admission-btn">Apply Now</a>
    </div>
</section>

<!-- STATS -->
<section class="stats">
    <div class="stats-container">

        <div class="stat-box">
            <h2>@ViewBag.TotalStudents+</h2>
            <p>Total Active Students</p>
        </div>

        <div class="stat-box">
            <h2>@ViewBag.TotalStaff+</h2>
            <p>Total Staff</p>
        </div>

        <div class="stat-box">
            <h2>@ViewBag.TotalAdminStaff+</h2>
            <p>Admin Staff</p>
        </div>

    </div>
</section>

<!-- TOPPERS -->
<section class="toppers">

    <h2>Our School Toppers</h2>

    <div class="toppers-grid">

        @if (ViewBag.TopperStudents != null)
        {
            foreach (var item in ViewBag.TopperStudents)
            {
                <div class="poster"
                     style="background-image:url('@item.FilePath');"
                     onclick="openTopperImage('@item.FilePath')">
                </div>
            }
        }

    </div>

</section>

<!-- TOPPER POPUP -->

<div class="topper-lightbox"
     id="topperLightbox">

    <span class="topper-close"
          onclick="closeTopperImage()">

        &times;

    </span>

    <img id="topperPopupImg" />

</div>


<section class="events">

    <h2>School Events</h2>

    @if (Model.Any())
    {
        <div class="diagonal-gallery">

            @foreach (var item in Model.Take(10))
            {
                var extension = System.IO.Path
                .GetExtension(item.FilePath)?
                .ToLower();

                bool isVideo =
                extension == ".mp4" ||
                extension == ".webm" ||
                extension == ".ogg";

                if (isVideo)
                {
                    <video class="event-media"
                           muted
                           onclick="openEventVideo('@item.FilePath')">

                        <source src="@item.FilePath" />

                    </video>
                }
                else
                {
                    <img src="@item.FilePath"
                         alt="@item.Title"
                         class="event-media"
                         onclick="openEventLightbox('@item.FilePath')" />
                }
            }

        </div>
    }

    <div class="gallery-btn-container">

        <a asp-controller="UserHome"
           asp-action="Gallery"
           class="gallery-btn">

            View Full Gallery →

        </a>

    </div>

</section>

<!-- IMAGE POPUP -->

<div class="event-lightbox"
     id="eventLightbox">

    <span class="event-close"
          onclick="closeEventLightbox()">

        &times;

    </span>

    <img id="eventPopupImg" />

</div>

<!-- VIDEO POPUP -->

<div class="event-video-popup"
     id="eventVideoPopup">

    <span class="event-close"
          onclick="closeEventVideo()">

        &times;

    </span>

    <video controls autoplay
           id="eventPopupVideo">

        <source id="eventPopupVideoSource" />

    </video>

</div>
