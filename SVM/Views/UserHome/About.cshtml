@{
    Layout = "~/Views/Shared/UserLayout.cshtml";
    ViewBag.Title = "About";
    ViewBag.ShowPreloader = false;
}
@section PageCss {
    <link rel="stylesheet" href="@Url.Content("~/css/UserSide_Css/About.css")" />
}
<!-- HERO -->
<br />
<div class="hero">
    <div class="hero-text">
        <h1>About Us</h1>
        <p>Sharda Vidyamandir & S.V.M English Medium School</p>
    </div>
</div>

<!-- SCHOOL -->

<div class="section">
    <div class="container">
        <h2>About Our School</h2>

        <p>
            Established with a vision to provide quality education, Sharda Vidyamandir & S.V.M English Medium School
            has been nurturing young minds with knowledge, discipline, and strong moral values. Our institution is
            committed to creating a balanced environment where students not only excel academically but also grow
            as responsible and confident individuals.
        </p>

        <p>
            Managed by the trusted Shiv Shakti Education Trust, our school offers both Gujarati and English medium
            education, ensuring accessibility and excellence for all learners. With experienced teachers, modern
            teaching methods, and a focus on overall development, we strive to build a strong foundation for every student.
        </p>

        <p>
            Along with academics, we encourage participation in sports, cultural activities, and social initiatives
            to develop creativity, teamwork, and leadership skills. Our goal is to shape students into capable citizens
            who are ready to face future challenges with confidence and integrity.
        </p>

        <p class="highlight">
            “Empowering Students with Knowledge, Values, and a Bright Future.”
        </p>
    </div>
</div>



<!-- TRUSTEE -->
<div class="section">
    <div class="container">
        <h2>Trustee</h2>

        <div class="profile reverse">


            <img src="/images/trustee.png">

            <div class="profile-text">
                <h3>Umakanat Sir</h3>
                <p> a dedicated and visionary trustee of Shiv Shakti Education Trust, has been a guiding force behind the continuous growth and success of our institution. His strong belief in discipline, quality education, and moral values has helped shape the school into a center of excellence.</p>
                <div class="message">"શિક્ષણ માત્ર જ્ઞાન મેળવવાનું સાધન નથી, પરંતુ સારા સંસ્કાર, મૂલ્યો અને ઉજ્જવળ ભવિષ્ય બનાવવા માટેનું શક્તિશાળી માધ્યમ છે. અમારું લક્ષ્ય જવાબદાર અને સંસ્કારી નાગરિકો તૈયાર કરવાનો છે."</div>
            </div>

        </div>
    </div>
</div>

<!-- DIRECTOR -->
<div class="section">
    <div class="container">
        <h2>Managing Director</h2>

        <div class="profile">
            <img src="/images/Managing Director.png">

            <div class="profile-text">
                <h3>Yogi Sir </h3>
                <p>
                    the Managing Director of Sharda Vidyamandir, is a visionary leader
                    committed to delivering quality education and building a strong foundation
                    for students. With dedication and experience, he continuously works towards
                    creating a disciplined, innovative, and inspiring learning environment.
                </p>
                <div class="message">
                    "Our mission is to empower every student with knowledge, values, and confidence
                    to achieve success in life."
                </div>
            </div>
        </div>

    </div>
</div>

<!-- PRINCIPALS -->
<div class="section">
    <div class="container">
        <h2>Our Principals</h2>

        <div class="multi-profile">

            <div class="multi-card">
                <img src="/images/hinapatel.png">
                <h4>Hina Patel</h4>
                <span class="role">Principal (Gujarati Medium - Primary Section)</span>
                <p>
                    Mrs. Hina Patel is a dedicated and caring educator who leads the
                    Gujarati Medium Primary Section with strong values and commitment.
                    She believes that early education should be rooted in culture,
                    discipline, and moral values.
                </p>
                <div class="message">
                    "બાળકમાં સંસ્કાર, શિસ્ત અને જ્ઞાનનું સંવર્ધન કરવું એ જ સાચું શિક્ષણ છે.
                    યોગ્ય માર્ગદર્શન અને સકારાત્મક વાતાવરણથી બાળકનો સર્વાંગી વિકાસ શક્ય બને છે."
                </div>
            </div>

            <div class="multi-card">
                <img src="/images/ChavdaSir.png">
                <h4>Narendrasinh Chavda</h4>
                <span class="role">Principal (Std. 9 to 12 – English & Gujarati Medium)</span>
                <p>
                    Mr. Narendrasinh Chavda is a dedicated and visionary educator who leads
                    the secondary and higher secondary sections (Std. 9 to 12) of both
                    English and Gujarati medium with excellence and commitment.
                </p>
                <div class="message">
                    "શિક્ષણ માત્ર ગુણ મેળવવા માટે નથી, પરંતુ સારા માનવી બનવા માટે છે.
                    મહેનત, શિસ્ત અને સંસ્કાર જ જીવનમાં સાચી સફળતા અપાવે છે."
                </div>
            </div>

            <div class="multi-card">
                <img src="/images/salinishrama.png">
                <h4> Salini Sharma</h4>
                <span class="role">Principal (English Primary Section)</span>
                <p>
                    Mrs. Salini Sharma is a passionate and nurturing educator who leads
                    the English Primary Section with dedication and care. She strongly
                    believes that early education is the foundation of a child’s future.
                </p>
                <div class="message">"Primary education forms the most important foundation of a child’s life. With love, care, and the right guidance, holistic development of every child becomes possible."</div>
            </div>

        </div>
    </div>
</div>

<!-- STAFF -->
<div class="section">
    <div class="container">
        <h2>Our Staff & Environment</h2>

        <div class="staff-box">

            <div class="staff-img">
                <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644">
            </div>

            <div class="profile-text">
                <p>
                    Our teachers are experienced, friendly and dedicated.
                </p>

                <ul>
                    <li> Experienced Teachers</li>
                    <li> Safe Environment</li>
                    <li> Personal Attention</li>
                    <li> Extra Activities</li>
                </ul>
            </div>

        </div>
    </div>
</div>

<!-- ACHIEVEMENTS -->
<div class="section">
    <div class="container">
        <h2>Our Achievements</h2>

        <div class="achievements">

            <div class="ach-box">
                <h2>25+</h2>
                <p>Years Experience</p>
            </div>

            <div class="ach-box">
                <h2>800+</h2>
                <p>Students</p>
            </div>

            <div class="ach-box">
                <h2>95%</h2>
                <p>Results</p>
            </div>

        </div>

    </div>
</div>