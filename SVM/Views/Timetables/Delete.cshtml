@model SVM.Models.Timetable
@{
    ViewData["Title"] = "Delete Timetable Entry";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />
<h2>Delete Timetable Entry</h2>
<h3>Are you sure you want to delete this?</h3>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-2">Day</dt>
        <dd class="col-sm-10">@Model.DayName</dd>

        <dt class="col-sm-2">Period</dt>
        <dd class="col-sm-10">@Model.LectureNo</dd>

        <dt class="col-sm-2">Subject</dt>
        <dd class="col-sm-10">@Model.Subject?.SubjectName</dd>

        <dt class="col-sm-2">Teacher</dt>
        <dd class="col-sm-10">
            @(Model.Staff != null ? $"{Model.Staff.FirstName} {Model.Staff.LastName}" : "Not Assigned")
        </dd>

        <dt class="col-sm-2">Time</dt>
        <dd class="col-sm-10">@Model.StartTime - @Model.EndTime</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="TimetableId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index"
           asp-route-sessionId="@ViewBag.ReturnSessionId"
           asp-route-classId="@ViewBag.ReturnClassId"
           asp-route-sectionId="@ViewBag.ReturnSectionId"
           asp-route-medium="@ViewBag.ReturnMedium"
           class="btn btn-secondary">Cancel</a>
    </form>
</div>