@model IEnumerable<SVM.Models.Class>

@{
	ViewData["Title"] = "Classes";
}

<!DOCTYPE html>
<html>
<head>
	<title>Classes</title>
	<link rel="stylesheet"
		  href="~/css/AdminSide_Css/ClassesDisplay.css"
		  asp-append-version="true" />
	<link rel="stylesheet"
		  href="~/css/AdminSide_Css/SearchBar.css"
		  asp-append-version="true" />
	<link rel="stylesheet"
		  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

	<div class="class-page">

		<!-- TOP BAR -->
		<div class="top-bar">
			<div class="left-side">
				<!-- SESSION FILTER -->
				<select id="sessionFilter" class="search-box">
					<option value="">All Sessions</option>

					@foreach (var s in (List<SVM.Models.Session>)ViewBag.AllSessions)
					{
						<option value="@s.SessionId"
								selected="@(s.SessionId == (int?)ViewBag.ActiveSessionId ? "selected" : null)">
							@s.SessionName
						</option>
					}
				</select>

				<!-- MEDIUM FILTER -->
				<select id="mediumFilter" class="filter-dropdown">
					<option value="all">All Mediums</option>

					@foreach (var m in (List<string>)ViewBag.MediumList)
					{
						<option value="@m">@m</option>
					}
				</select>

				<select id="searchInput" class="search-box">
					<option value="">All Classes</option>

					@foreach (var c in (List<string>)ViewBag.ClassNames)
					{
						<option value="@c">@c</option>
					}
				</select>

				<!-- SEARCH BUTTON -->
				<button class="search-btn" onclick="filterClasses()">
					<i class="fa-solid fa-magnifying-glass"></i>
					Search
				</button>

				<!-- RESET BUTTON -->
				<button class="reset-btn" onclick="resetFilter()">
					Reset
				</button>
			</div>

			<!-- ADD BUTTON with filters -->
			<a asp-action="Create"
			   asp-route-medium="@ViewBag.SelectedMedium"
			   asp-route-className="@ViewBag.SelectedClassName"
			   asp-route-sessionId="@ViewBag.SelectedSessionId"
			   class="add-btn">
				<i class="fa-solid fa-plus"></i>
			</a>
		</div>

		<!-- NO DATA MESSAGE -->
		<div id="noDataMessage" class="no-data">
			Select filters and click Search
		</div>

		<!-- CLASS CONTAINER -->
		<div class="class-container">
			@foreach (var item in Model)
			{
				<div class="class-card"
					 data-medium="@item.Medium"
					 data-session="@item.SessionId"
					 data-classname="@item.ClassName"
					 data-classid="@item.ClassId"
					 style="display:none;">

					<!-- CARD HEADER -->
					<div class="card-header">
						<div>
							<div class="class-badge">Class @item.ClassName</div>
							<p class="medium-text">@item.Medium Medium</p>
						</div>
						<div class="right-info">
							<div class="session-badge">@item.Session?.SessionName</div>
							<div class="count-info">
								@item.Students.Count Students |
								@item.Sections.Count Sections
							</div>
						</div>
					</div>

					<!-- SECTION LIST -->
					<div class="section-list">
						@foreach (var sec in item.Sections)
						{
							<div class="section-row">
								<div class="section-name">Section @sec.SectionName</div>
								<div class="section-actions">
									<a asp-controller="Sections"
									   asp-action="Edit"
									   asp-route-id="@sec.SectionId"
									   asp-route-medium="@item.Medium"
									   asp-route-className="@item.ClassName"
									   asp-route-sessionId="@item.SessionId"
									   class="sec-icon edit"
									   title="Edit Section">
										<i class="fa-solid fa-pen"></i>
									</a>
									<a asp-controller="Sections"
									   asp-action="Delete"
									   asp-route-id="@sec.SectionId"
									   asp-route-medium="@item.Medium"
									   asp-route-className="@item.ClassName"
									   asp-route-sessionId="@item.SessionId"
									   class="sec-icon delete"
									   title="Delete Section">
										<i class="fa-solid fa-trash"></i>
									</a>
								</div>
							</div>
						}
						<div class="section-add">
							<a asp-controller="Sections"
							   asp-action="Create"
							   asp-route-classId="@item.ClassId"
							   asp-route-medium="@item.Medium"
							   asp-route-className="@item.ClassName"
							   asp-route-sessionId="@item.SessionId"
							   class="add-section-btn">
								<i class="fa-solid fa-plus"></i> Add Section
							</a>
						</div>
					</div>

					<!-- ACTION BUTTONS - UPDATED WITH FILTERS -->
					<div class="action-buttons">
						<a asp-action="Edit"
						   asp-route-id="@item.ClassId"
						   asp-route-medium="@ViewBag.SelectedMedium"
						   asp-route-className="@ViewBag.SelectedClassName"
						   asp-route-sessionId="@ViewBag.SelectedSessionId"
						   class="edit-btn">
							<i class="fa-solid fa-pen"></i> Edit
						</a>
						<a asp-action="Details"
						   asp-route-id="@item.ClassId"
						   asp-route-medium="@ViewBag.SelectedMedium"
						   asp-route-className="@ViewBag.SelectedClassName"
						   asp-route-sessionId="@ViewBag.SelectedSessionId"
						   class="details-btn">
							<i class="fa-solid fa-eye"></i> Details
						</a>
						<a asp-action="Delete"
						   asp-route-id="@item.ClassId"
						   asp-route-medium="@ViewBag.SelectedMedium"
						   asp-route-className="@ViewBag.SelectedClassName"
						   asp-route-sessionId="@ViewBag.SelectedSessionId"
						   class="delete-btn">
							<i class="fa-solid fa-trash"></i> Delete
						</a>
					</div>
				</div>
			}
		</div>
	</div>

	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
	<script>
		$(document).ready(function() {
			var selectedMedium = '@ViewBag.SelectedMedium';
			var selectedClassName = '@ViewBag.SelectedClassName';
			var selectedSessionId = '@ViewBag.SelectedSessionId';
			var selectedClassId = '@ViewBag.SelectedClassId';

			// Set dropdown values
			if (selectedMedium && selectedMedium !== '') {
				$('#mediumFilter').val(selectedMedium);
			}

			if (selectedClassName && selectedClassName !== '') {
				$('#searchInput').val(selectedClassName);
			}

			if (selectedSessionId && selectedSessionId !== '' && selectedSessionId !== '0') {
				$('#sessionFilter').val(selectedSessionId);
			}

			document.querySelectorAll(".class-card").forEach(card => {
				card.style.display = "none";
			});

			if (selectedClassId && selectedClassId !== '' && selectedClassId !== '0') {
				showSpecificClass(selectedClassId);
			}
			else if (selectedMedium !== '' || selectedClassName !== '' || selectedSessionId !== '') {
				filterClasses();
			}
			else {
				let noDataMsg = document.getElementById("noDataMessage");
				noDataMsg.style.display = "block";
				noDataMsg.style.color = "#6b7280";
				noDataMsg.innerHTML = "Select filters and click Search";
			}
		});

		function showSpecificClass(classId) {
			let cards = document.querySelectorAll(".class-card");
			let visible = 0;

			cards.forEach(card => {
				let cardClassId = card.getAttribute('data-classid');

				if (cardClassId == classId) {
					card.style.display = "block";
					visible++;

					card.style.transition = 'all 0.3s ease';
					card.style.boxShadow = '0 0 0 3px rgba(40, 167, 69, 0.5)';
					card.style.border = '2px solid #28a745';
					setTimeout(() => {
						card.style.boxShadow = '';
						card.style.border = '';
					}, 3000);

					card.scrollIntoView({ behavior: 'smooth', block: 'center' });
				} else {
					card.style.display = "none";
				}
			});

			
			let noDataMsg = document.getElementById("noDataMessage");
			if (visible === 0) {
				noDataMsg.style.display = "block";
				noDataMsg.style.color = "red";
				noDataMsg.innerHTML = "Class not found";
			} else {
				noDataMsg.style.display = "none";
			}
		}

		function filterClasses() {
			let sessionValue = document.getElementById("sessionFilter").value;
			let searchValue = document.getElementById("searchInput").value.toLowerCase().trim();
			let mediumValue = document.getElementById("mediumFilter").value.toLowerCase();

			let cards = document.querySelectorAll(".class-card");
			let visible = 0;

			// Apply filters
			cards.forEach(card => {
				let cardSession = card.getAttribute("data-session") || "";
				let className = card.querySelector(".class-badge")?.innerText.toLowerCase() || "";
				let cardMedium = card.getAttribute("data-medium")?.toLowerCase() || "";

				let sessionMatch = sessionValue === "" || cardSession === sessionValue;
				let searchMatch = searchValue === "" || className.includes(searchValue);
				let mediumMatch = mediumValue === "all" || cardMedium === mediumValue;

				if (sessionMatch && searchMatch && mediumMatch) {
					card.style.display = "block";
					visible++;
				} else {
					card.style.display = "none";
				}
			});

			let noDataMsg = document.getElementById("noDataMessage");
			if (visible === 0) {
				noDataMsg.style.display = "block";
				noDataMsg.style.color = "red";
				noDataMsg.innerHTML = "No Class Found";
			} else {
				noDataMsg.style.display = "none";
			}
		}

		function resetFilter() {
			document.getElementById("sessionFilter").value = "";
			document.getElementById("searchInput").value = "";
			document.getElementById("mediumFilter").value = "all";

			document.querySelectorAll(".class-card").forEach(card => {
				card.style.display = "none";
			});

			let noDataMsg = document.getElementById("noDataMessage");
			noDataMsg.style.display = "block";
			noDataMsg.style.color = "#6b7280";
			noDataMsg.innerHTML = "Select filters and click Search";
		}
	</script>
</body>
</html>