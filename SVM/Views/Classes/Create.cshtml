@model SVM.Models.Class

@{
	ViewData["Title"] = "Create";
}

<!DOCTYPE html>
<html>
<head>
	<link rel="stylesheet" href="~/css/CreateForm.css" asp-append-version="true" />
	<title>Create Class</title>
</head>
<body>
	<div class="container">
		<h4>Add Class</h4>
		<hr />

		<div class="row">
			<div class="col-md-4">
				<form asp-action="Create">
					<div asp-validation-summary="ModelOnly" class="text-danger"></div>
					<div class="form-group">
						<label asp-for="Medium" class="control-label"></label>
						<select asp-for="Medium" class="form-control" asp-items="ViewBag.MediumList">
							<option value="">-- Select Medium --</option>
						</select>
						<span asp-validation-for="Medium" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label asp-for="ClassName" class="control-label"></label>
						<input asp-for="ClassName" class="form-control" />
						<span asp-validation-for="ClassName" class="text-danger"></span>
					</div>


					<div class="form-group">
						<label asp-for="Session.SessionName" class="control-label"></label>
						<select asp-for="SessionId" class="form-control" asp-items="ViewBag.SessionId"></select>
					</div>

					<div class="form-group">
						<input type="submit" value="Create" class="btn btn-primary" />
					</div>
				</form>

				<!-- Back to List link -->
				<div class="back-link">
					<a asp-action="Index">← Back to List</a>
				</div>
			</div>
		</div>
	</div>
</body>
</html>