@model SVM.Models.Class

@{
	ViewData["Title"] = "Create";
}

<!DOCTYPE html>
<html>
<head>
	<link rel="stylesheet" href="~/css/AdminSide_Css/Forms.css" asp-append-version="true" />
	<title>Create Class</title>
</head>

<body>

	<div class="session-page">

		<div class="session-card">

			<h3 class="card-title">Add Class</h3>

			<form asp-action="Create">

				<div class="form-grid">

					<div class="form-group">
						<label asp-for="Session.SessionName" class="control-label"></label>
						<select asp-for="SessionId" class="form-control" asp-items="ViewBag.SessionId" id="SessionId"></select>
					</div>

					<div class="form-group">
						<label asp-for="Medium" class="control-label"></label>
						<select asp-for="Medium" class="form-control" asp-items="ViewBag.MediumList" id="Medium">
							<option value="">-- Select Medium --</option>
						</select>
						<span asp-validation-for="Medium" class="text-danger"></span>
					</div>

					<div class="form-group">
						<label asp-for="ClassName" class="control-label"></label>

						<select asp-for="ClassName" class="form-control" id="ClassName">
							<option value="">-- Select Class --</option>

							@foreach (var c in (ViewBag.ClassNames as List<string> ?? new List<string>()))
							{
								<option value="@c">@c</option>
							}

						</select>

						<span asp-validation-for="ClassName" class="text-danger"></span>
					</div>

				</div>

				<div style="display:flex; gap:15px; flex-wrap:wrap;">

					<input type="submit" value="Create" class="create-btn" />

					<!-- Back to List button - Get current values from form -->
					<button type="button" class="Back-btn" onclick="goBackWithFilters()">← Back to List</button>

				</div>

			</form>

		</div>

	</div>

	<script>
		function goBackWithFilters() {
			// Get elements by their IDs
			var medium = document.getElementById("Medium");
			var className = document.getElementById("ClassName");
			var sessionId = document.getElementById("SessionId");

			var mediumValue = medium ? medium.value : '';
			var classNameValue = className ? className.value : '';
			var sessionIdValue = sessionId ? sessionId.value : '';

			console.log("Medium:", mediumValue);
			console.log("ClassName:", classNameValue);
			console.log("SessionId:", sessionIdValue);

			var url = '/Classes/Index?';

			if (mediumValue && mediumValue !== '') {
				url += 'medium=' + encodeURIComponent(mediumValue) + '&';
			}
			if (classNameValue && classNameValue !== '') {
				url += 'className=' + encodeURIComponent(classNameValue) + '&';
			}
			if (sessionIdValue && sessionIdValue !== '') {
				url += 'sessionId=' + encodeURIComponent(sessionIdValue) + '&';
			}

			// Remove trailing '&' or '?' if no parameters
			if (url.endsWith('&')) {
				url = url.slice(0, -1);
			}
			if (url === '/Classes/Index?') {
				url = '/Classes/Index';
			}

			window.location.href = url;
		}
	</script>

</body>
</html>