@model SVM.Models.Class

@{
    ViewData["Title"] = "Edit";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/AdminSide_Css/Forms.css" asp-append-version="true" />
    <title>Edit Class</title>
</head>

<body>

    <div class="session-page">

        <h2 class="page-title">Edit Class</h2>

        <div class="session-card">

            <h3 class="card-title">Update Class Details</h3>

            <form asp-action="Edit">

                <input type="hidden" asp-for="ClassId" />

                <div class="form-grid">

                    <div class="form-group">
                        <label asp-for="Session.SessionName" class="control-label"></label>
                        <select asp-for="SessionId" class="form-control" asp-items="ViewBag.SessionId"></select>
                        <span asp-validation-for="SessionId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Medium" class="control-label"></label>
                        <select asp-for="Medium" class="form-control" asp-items="ViewBag.MediumList">
                            <option value="">-- Select Medium --</option>
                        </select>
                        <span asp-validation-for="Medium" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ClassName" class="control-label"></label>

                        <select asp-for="ClassName" class="form-control">
                            <option value="">-- Select Class --</option>

                            @foreach (var c in (ViewBag.ClassNames as List<string> ?? new List<string>()))
                            {
                                <option value="@c">@c</option>
                            }
                        </select>

                        <span asp-validation-for="ClassName" class="text-danger"></span>
                    </div>

                   

                </div>

                <div style="display:flex; gap:15px; flex-wrap:wrap;">

                    <input type="submit" value="Save" class="create-btn" />

                    <a asp-action="Index">
                        <button type="button" class="Back-btn">← Back to List</button>
                    </a>

                </div>

            </form>

        </div>

    </div>

</body>
</html>