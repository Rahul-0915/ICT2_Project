@model SVM.Models.Student

@{
	ViewData["Title"] = "Delete";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
	<h4>Student</h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.AdmissionNo)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.AdmissionNo)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.AdmissionDate)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.AdmissionDate)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.RollNo)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.RollNo)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.FirstName)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.FirstName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.LastName)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.LastName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.FatherName)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.FatherName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Dob)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Dob)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Gender)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Gender)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Grno)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Grno)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.BloodGroup)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.BloodGroup)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.AadharNo)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.AadharNo)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Address)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Address)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.City)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.City)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.State)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.State)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Pincode)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Pincode)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Phone)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Phone)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.MotherPhone)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.MotherPhone)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.PreviousSchool)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.PreviousSchool)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.StudentPhoto)
		</dt>
		<dd class="col-sm-10">
			@if (!string.IsNullOrEmpty(Model.StudentPhoto))
			{
				<img src="@Model.StudentPhoto" alt="Student Photo" style="max-width:200px; max-height:200px; border:1px solid #ddd; border-radius:4px; padding:5px;" />
			}
			else
			{
				<span>No photo available</span>
			}
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Class)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Class.ClassName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Section)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Section.SectionName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Session)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Session.SessionName)
		</dd>
		<dt class="col-sm-2">
			<label>Added By</label>
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.User.FullName)
		</dd>
	</dl>

	<form asp-action="Delete">
		<input type="hidden" asp-for="StudentId" />
		<input type="submit" value="Delete" class="btn btn-danger" /> |
		<a asp-action="Index">Back to List</a>
	</form>
</div>
