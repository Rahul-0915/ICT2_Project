@model IEnumerable<SVM.Models.Student>

@{
    ViewData["Title"] = "Student ID Cards";
}

<link rel="stylesheet"
      href="~/css/AdminSide_Css/SearchBar.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="~/css/AdminSide_Css/StudentList.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Gujarati:wght@400;500;700;800&display=swap"
      rel="stylesheet">

<div class="id-page">

    <!-- TOP SEARCH BAR -->

    <div class="top-bar">

        <div class="left-side">

            <!-- SESSION -->

            <select id="sessionFilter" class="search-box">
                <option value="">Select Session</option>

                @foreach (var s in Model
                .Where(x => x.Session != null)
                .Select(x => x.Session)
                .DistinctBy(x => x.SessionId))
                {
                    <option value="@s.SessionId">
                        @s.SessionName
                    </option>
                }

            </select>

            <!-- MEDIUM -->

            <select id="mediumFilter" class="search-box">

                <option value="">Select Medium</option>
                <option value="Gujarati">Gujarati</option>
                <option value="English">English</option>

            </select>

            <!-- CLASS -->

            <select id="classFilter" class="search-box">

                <option value="">Select Class</option>

            </select>

            <!-- SECTION -->

            <select id="sectionFilter" class="search-box">

                <option value="">Select Section</option>

            </select>

            <!-- SEARCH -->

            <button type="button"
                    class="search-btn"
                    onclick="searchStudents()">

                <i class="fa-solid fa-magnifying-glass"></i>
                Search

            </button>

            <!-- RESET -->

            <button type="button"
                    class="reset-btn"
                    onclick="resetFilters()">

                Reset

            </button>

        </div>
        <a asp-action="Create"
           class="add-btn">

            <i class="fa-solid fa-plus"></i>

        </a>

    </div>

    <!-- TITLE -->

    <div class="result-title" id="resultTitle">
    </div>

    <!-- ACTION BAR -->

    <div class="action-bar" id="actionBar">

        <div class="inner-search">

            <input type="text"
                   id="studentSearch"
                   placeholder="Search by Roll No or Student Name..."
                   onkeyup="filterCurrentData()" />

            <div class="action-buttons">

                <button class="view-btn"
                        id="toggleViewBtn"
                        onclick="toggleView()">

                    Table View

                </button>

                <button class="pdf-btn"
                        onclick="downloadPDF()">

                    <i class="fa-solid fa-file-pdf"></i>
                    Download PDF

                </button>

                <button class="excel-btn"
                        onclick="downloadExcel()">

                    <i class="fa-solid fa-file-excel"></i>
                    Excel

                </button>

            </div>
        </div>


    </div>

    <!-- NO DATA -->

    <div class="no-data" id="noData">

        Select filters and search students

    </div>

    <!-- ID CARD CONTAINER -->

    <div class="card-grid"
         id="cardContainer">

        @foreach (var item in Model)
        {
            var medium = item.Class?.Medium ?? "";

            var schoolName =
            medium == "English"
            ? "S.V.M ENGLISH MEDIUM SCHOOL"
            : "શારદા વિદ્યામંદિર";

            var logo =
            medium == "English"
            ? "/images/SVMEng_logo.png"
            : "/images/SVMGuj_logo.png";

            <div class="id-card student-card"
                 data-id="@item.StudentId"
                 data-session="@item.SessionId"
                 data-medium="@medium"
                 data-class="@item.ClassId"
                 data-section="@item.SectionId"
                 data-roll="@item.RollNo"
                 data-name="@($"{item.FirstName} {item.LastName}")"
                 style="display:none;">

                <!-- HEADER -->

                <div class="card-top">

                    <div class="top-left">

                        <img src="@logo"
                             class="school-logo" />

                    </div>

                    <div class="top-right">

                        <div class="school-name">

                            @schoolName

                        </div>

                        <div class="school-tag">

                            STUDENT IDENTITY CARD

                        </div>

                    </div>

                </div>

                <!-- BODY -->

                <div class="card-body">

                    <!-- PHOTO -->

                    <div class="student-photo-box">

                        @if (!string.IsNullOrEmpty(item.StudentPhoto))
                        {
                            <img src="@item.StudentPhoto"
                                 class="student-photo" />
                        }
                        else
                        {
                            <img src="/images/default-user.png"
                                 class="student-photo" />
                        }

                    </div>

                    <!-- DETAILS -->

                    <div class="student-details">

                        <h2>

                            @item.FirstName
                            @item.LastName

                        </h2>

                        <div class="detail-row">

                            <span>STD : </span>
                            <p>@item.Class?.ClassName</p>

                        </div>

                        <div class="detail-row">

                            <span>DIV : </span>
                            <p>@item.Section?.SectionName</p>

                        </div>

                        <div class="detail-row">

                            <span>ROLL : </span>
                            <p>@item.RollNo</p>

                        </div>

                        <div class="detail-row">

                            <span>GR NO : </span>
                            <p>@item.Grno</p>

                        </div>

                        <div class="detail-row">

                            <span>DOB : </span>
                            <p>@(item.Dob.HasValue ? item.Dob.Value.ToString("dd-MM-yyyy") : "")</p>

                        </div>

                        <div class="detail-row">

                            <span>PHONE : </span>
                            <p>@item.Phone</p>

                        </div>

                        <div class="address-row">

                            <span>ADDRESS : </span>

                            <p>

                                @item.Address

                            </p>

                        </div>

                    </div>

                </div>

                <!-- FOOTER -->

                <div class="card-footer">

                    <div>

                        Gujarat Housing Board,
                        Pandesara, Surat

                    </div>

                    <div>

                        +91 9876543210

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- TABLE VIEW -->

    <div class="table-wrapper"
         id="tableWrapper">

        <table class="student-table">

            <thead>

                <tr>

                    <th>Roll No</th>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>GR No</th>
                    <th>Phone</th>
                    <th>Class</th>
                    <th>Section</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody id="tableBody">
            </tbody>

        </table>

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    let tableMode = false;

    $(document).ready(function () {

        $("#actionBar").hide();
        $("#tableWrapper").hide();

        $("#mediumFilter").change(function () {

            let medium = $(this).val();

            $("#classFilter").html('<option value="">Select Class</option>');
            $("#sectionFilter").html('<option value="">Select Section</option>');

            if (medium != "") {

                $.ajax({

                    url: '@Url.Action("GetClassesByMedium", "Students")',

                    type: 'GET',

                    data: { medium: medium },

                    success: function (data) {

                        $.each(data, function (i, item) {

                            $("#classFilter").append(

                                `<option value="${item.value}">
                                            ${item.text}
                                        </option>`

                            );

                        });

                    }

                });

            }

        });

        $("#classFilter").change(function () {

            let classId = $(this).val();

            $("#sectionFilter").html('<option value="">Select Section</option>');

            if (classId != "") {

                $.ajax({

                    url: '@Url.Action("GetSectionsByClass", "Students")',

                    type: 'GET',

                    data: { classId: classId },

                    success: function (data) {

                        $.each(data, function (i, item) {

                            $("#sectionFilter").append(

                                `<option value="${item.value}">
                                            ${item.text}
                                        </option>`

                            );

                        });

                    }

                });

            }

        });

    });

    function searchStudents() {

        let session =
            $("#sessionFilter").val();

        let medium =
            $("#mediumFilter").val();

        let classId =
            $("#classFilter").val();

        let sectionId =
            $("#sectionFilter").val();

        if (!session || !medium || !classId || !sectionId) {

            alert("Please select all filters");

            return;
        }

        let cards =
            document.querySelectorAll(".student-card");

        let visible = 0;

        cards.forEach(card => {

            let match =
                card.dataset.session == session &&
                card.dataset.medium == medium &&
                card.dataset.class == classId &&
                card.dataset.section == sectionId;

            if (match) {

                card.style.display = "flex";

                visible++;

            } else {

                card.style.display = "none";

            }

        });

        if (visible > 0) {

            $("#actionBar").show();

            $("#noData").hide();

            let classText =
                $("#classFilter option:selected").text();

            let sectionText =
                $("#sectionFilter option:selected").text();

            let mediumText =
                medium + " Medium";

            $("#resultTitle").html(

                `${mediumText} | ${classText} | Section ${sectionText}`

            );

            buildTable();

        }
        else {

       

        }

    }

    function filterCurrentData() {

        let value =
            $("#studentSearch").val().toLowerCase();

        let session =
            $("#sessionFilter").val();

        let medium =
            $("#mediumFilter").val();

        let classId =
            $("#classFilter").val();

        let sectionId =
            $("#sectionFilter").val();

        let cards =
            document.querySelectorAll(".student-card");

        let visible = 0;

        cards.forEach(card => {

            // First filter by selected dropdowns
            let matchFilter =
                card.dataset.session == session &&
                card.dataset.medium == medium &&
                card.dataset.class == classId &&
                card.dataset.section == sectionId;

            if (matchFilter) {

                let name =
                    card.dataset.name.toLowerCase();

                let roll =
                    card.dataset.roll.toLowerCase();

                // Then search by name/roll
                if (name.includes(value) || roll.includes(value)) {

                    card.style.display = "flex";

                    visible++;

                } else {

                    card.style.display = "none";

                }

            } else {

                card.style.display = "none";

            }

        });

        buildTable();

    }

    function toggleView() {

        tableMode = !tableMode;

        if (tableMode) {

            $("#cardContainer").hide();
            $("#tableWrapper").show();

            $("#toggleViewBtn").text("Card View");

        }
        else {

            $("#cardContainer").show();
            $("#tableWrapper").hide();

            $("#toggleViewBtn").text("Table View");

        }

    }



    function buildTable() {

        let html = "";

        $(".student-card").each(function () {

            if ($(this).css("display") != "none") {

                // DATA
                let id =
                    $(this).data("id");

                let name =
                    $(this).data("name");

                let roll =
                    $(this).data("roll");

                let cls =
                    $(this).find(".detail-row p").eq(0).text();

                let sec =
                    $(this).find(".detail-row p").eq(1).text();

                let gr =
                    $(this).find(".detail-row p").eq(3).text();

                let phone =
                    $(this).find(".detail-row p").eq(5).text();

                let photo =
                    $(this).find(".student-photo").attr("src");

                html += `

                    <tr>

                        <td>${roll}</td>

                        <td>
                            <img src="${photo}"
                                 class="table-photo">
                        </td>

                        <td>${name}</td>

                        <td>${gr}</td>

                        <td>${phone}</td>

                        <td>${cls}</td>

                        <td>${sec}</td>

                        <td class="table-actions">

                            <a href="/Students/Edit/${id}">
                                Edit
                            </a>

                            <a href="/Students/Details/${id}">
                                View
                            </a>

                            <a href="/Students/Delete/${id}">
                                Delete
                            </a>

                        </td>

                    </tr>

                `;

            }

        });

        $("#tableBody").html(html);

    }
    async function downloadPDF() {

        await document.fonts.ready;

        let cards = [...document.querySelectorAll(".student-card")]
            .filter(x => x.style.display != "none");

        if (cards.length == 0) {

            alert("No cards found");
            return;
        }

        // MAIN PDF AREA
        let printArea = document.createElement("div");

        printArea.style.width = "100%";
        printArea.style.display = "grid";

        // 2 CARDS PER ROW
        printArea.style.gridTemplateColumns = "repeat(2, 1fr)";

        // VERY SMALL GAP
        printArea.style.columnGap = "2px";
        printArea.style.rowGap = "2px";

        printArea.style.padding = "2px";
        printArea.style.background = "white";

        cards.forEach(card => {

            let clone = card.cloneNode(true);

            clone.style.display = "flex";

            // CARD SIZE
            clone.style.width = "370px";
            clone.style.minHeight = "215px";

            clone.style.margin = "0 auto";

            clone.style.borderRadius = "10px";
            clone.style.border = "1px solid #ddd";

            clone.style.boxShadow = "none";
            clone.style.overflow = "hidden";

            // HEADER
            let top = clone.querySelector(".card-top");

            top.style.padding = "7px";
            top.style.gap = "7px";

            // LOGO
            let logo = clone.querySelector(".school-logo");

            logo.style.width = "38px";
            logo.style.height = "38px";

            // SCHOOL NAME
            let schoolName = clone.querySelector(".school-name");

            schoolName.style.fontSize = "14px";
            schoolName.style.fontWeight = "800";
            schoolName.style.lineHeight = "1.1";

            // IMPORTANT FOR GUJARATI
            schoolName.style.fontFamily =
                "'Noto Sans Gujarati','Arial Unicode MS',sans-serif";

            // TAG
            let tag = clone.querySelector(".school-tag");

            tag.style.fontSize = "8px";

            // BODY
            let body = clone.querySelector(".card-body");

            body.style.padding = "8px";
            body.style.gap = "8px";

            // PHOTO
            let photo = clone.querySelector(".student-photo");

            photo.style.width = "75px";
            photo.style.height = "90px";

            // PHOTO BOX
            let photoBox = clone.querySelector(".student-photo-box");

            photoBox.style.width = "75px";
            photoBox.style.minWidth = "75px";

            // NAME
            let studentName = clone.querySelector(".student-details h2");

            studentName.style.fontSize = "14px";
            studentName.style.marginBottom = "5px";

            // DETAILS
            clone.querySelectorAll(".detail-row").forEach(row => {

                row.style.marginBottom = "2px";

                let span = row.querySelector("span");
                let p = row.querySelector("p");

                span.style.width = "48px";
                span.style.fontSize = "8px";

                p.style.fontSize = "9px";
            });

            // ADDRESS
            let addressSpan = clone.querySelector(".address-row span");
            let addressP = clone.querySelector(".address-row p");

            addressSpan.style.fontSize = "8px";

            addressP.style.fontSize = "7px";
            addressP.style.lineHeight = "1.1";

            // FOOTER
            let footer = clone.querySelector(".card-footer");

            footer.style.fontSize = "6px";
            footer.style.padding = "4px 6px";

            printArea.appendChild(clone);

        });

        html2pdf().set({

            margin: 2,

            filename: 'Student-ID-Cards.pdf',

            image: {
                type: 'jpeg',
                quality: 1
            },

            html2canvas: {

                scale: 4,
                useCORS: true,
                letterRendering: true

            },

            jsPDF: {

                unit: 'mm',
                format: 'a4',

                // PORTRAIT
                orientation: 'portrait'
            }

        }).from(printArea).save();
    }

    function downloadExcel() {
        let rows = [];

        // Get filter values for heading
        let mediumText = $("#mediumFilter option:selected").val() || "";
        let classText = $("#classFilter option:selected").text() || "";
        let sectionText = $("#sectionFilter option:selected").text() || "";

        // Add Main Heading
        rows.push([`${mediumText} Medium | ${classText} | Section ${sectionText}`]);
        rows.push([]); // Empty row

        // Add Column Headers
        rows.push(["Roll No", "Student Name", "Class", "Section", "GR No", "Phone", "DOB", "Address"]);

        // Add Student Data
        $(".student-card").each(function () {
            if ($(this).css("display") != "none") {
                let roll = $(this).data("roll");
                let name = $(this).data("name");
                let cls = $(this).find(".detail-row p").eq(0).text();
                let sec = $(this).find(".detail-row p").eq(1).text();
                let gr = $(this).find(".detail-row p").eq(3).text();
                let phone = $(this).find(".detail-row p").eq(5).text();
                let dob = $(this).find(".detail-row p").eq(4).text();
                let address = $(this).find(".address-row p").text();

                rows.push([roll, name, cls, sec, gr, phone, dob, address]);
            }
        });

        let ws = XLSX.utils.aoa_to_sheet(rows);

        // Set column widths
        ws['!cols'] = [
            { wch: 12 },  // Roll No
            { wch: 25 },  // Name
            { wch: 12 },  // Class
            { wch: 10 },  // Section
            { wch: 15 },  // GR No
            { wch: 15 },  // Phone
            { wch: 15 },  // DOB
            { wch: 40 }   // Address
        ];

        // Merge heading cells (first row spans all columns)
        if (!ws['!merges']) ws['!merges'] = [];
        ws['!merges'].push({ s: { r: 0, c: 0 }, e: { r: 0, c: 7 } });

        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Students");
        XLSX.writeFile(wb, "Students_List.xlsx");
    }

    function resetFilters() {

        location.reload();

    }

</script>