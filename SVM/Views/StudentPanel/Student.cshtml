<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	$(document).ready(function() {
	loadDashboardData();
	});

	function loadDashboardData() {
	// Load Notices
	$.get('/StudentPanel/GetActiveNotices')
	.done(function(notices) {
	var noticeHtml = '';
	if (notices && notices.length > 0) {
	notices.slice(0, 5).forEach(function(notice) {
	var date = notice.createdAt ? new Date(notice.createdAt) : new Date();
	noticeHtml += `
	<li class="notice-item">
	<div class="notice-icon">
	<i class="fas fa-bullhorn"></i>
	</div>
	<div class="notice-content">
	<div class="notice-title">${escapeHtml(notice.title || 'Notice')}</div>
	<div class="notice-date">${date.toLocaleDateString()}</div>
	</div>
	</li>
	`;
	});
	} else {
	noticeHtml = '<li class="empty-state"><i class="fas fa-inbox"></i><p>No notices available</p></li>';
	}
	$('#noticeList').html(noticeHtml);
	})
	.fail(function() {
	$('#noticeList').html('<li class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load notices</p></li>');
	});

	// Load Today's Timetable
	loadTodayTimetable();

	// Load Attendance
	loadAttendance();

	// Load Subjects Count
	$.get('/StudentPanel/GetSubjectsCount')
	.done(function(data) {
	$('#totalSubjects').text(data.count || '0');
	})
	.fail(function() {
	$('#totalSubjects').text('0');
	});

	// Load Results Count (Published Results)
	$.get('/StudentPanel/GetPublishedResultsCount')
	.done(function(data) {
	$('#resultsCount').text(data.count || '0');
	})
	.fail(function() {
	$('#resultsCount').text('0');
	});

	// Load Latest Exam Result
		$.get('/StudentPanel/GetLatestExamResult')
			.done(function (data) {
				if (data.hasResult && data.examName) {
					$('#latestResultCard').show();

					let html = `
				<ul class="notice-list">
					<li class="notice-item">
						<div class="notice-icon">
							<i class="fas fa-file-alt"></i>
						</div>
						<div class="notice-content">
							<div class="notice-title">${escapeHtml(data.examName)}</div>
							<div class="notice-date">Exam result has been declared </div>
						</div>
					</li>
				</ul>
			`;
					$('#latestResultContent').html(html);
				} else {
					$('#latestResultCard').hide();
				}
			})

	// Load Pending Fees
	$.get('/StudentPanel/GetPendingFees')
	.done(function(data) {
	var amount = data.amount || 0;
	$('#pendingFees').text('₹' + amount.toLocaleString());
	})
	.fail(function() {
	$('#pendingFees').text('₹0');
	});
	}

	function loadTodayTimetable() {
	$.get('/StudentPanel/GetTodayTimetable')
	.done(function(data) {
	var html = '';
	if (data && data.length > 0) {
	var today = new Date().toLocaleDateString('en-US', { weekday: 'long' });
	html = `<div class="tt-day">📅 ${today}</div>`;
	data.forEach(function(subject) {
	html += `
	<div class="tt-subject">
	<span class="subject-name">${escapeHtml(subject.subjectName)}</span>
	<span class="subject-time">${subject.startTime} - ${subject.endTime}</span>
	</div>
	`;
	});
	} else {
	html = '<div class="empty-state"><i class="fas fa-calendar-day"></i><p>No classes scheduled for today</p></div>';
	}
	$('#todayTimetable').html(html);
	})
	.fail(function() {
	$('#todayTimetable').html('<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load timetable</p></div>');
	});
	}

	function loadAttendance() {
	console.log('Fetching attendance summary...');

	$.get('/StudentPanel/GetAttendanceSummary')
	.done(function(data) {
	console.log('Attendance Summary Response:', data);
	var html = '';

	// Check if we have valid attendance data
	if (data && data.percentage > 0) {
	var percentage = data.percentage;
	var presentDays = data.present;
	var absentDays = data.absent;
	var totalDays = presentDays + absentDays;

	console.log('Present Days:', presentDays, 'Absent Days:', absentDays, 'Total Days:', totalDays, 'Percentage:', percentage);

	var circumference = 2 * Math.PI * 65;
	var dashArray = (percentage / 100) * circumference;

	// If dashArray is 0, set a tiny value to still show the ring
	if (dashArray === 0 && percentage === 0) {
	dashArray = 1;
	}

	html = `
	<div class="attendance-ring">
	<svg width="150" height="150" viewBox="0 0 150 150">
	<circle cx="75" cy="75" r="65" class="ring-bg" />
	<circle cx="75" cy="75" r="65" class="ring-progress"
	stroke-dasharray="${dashArray} ${circumference}"
	transform="rotate(-90 75 75)" />
	</svg>
	<div class="attendance-percent">
	<div class="percent">${percentage}%</div>
	<div class="label">Attendance</div>
	</div>
	</div>
	<div class="attendance-detail">
	<div class="detail-item">
	<div class="detail-value">${presentDays}</div>
	<div class="detail-label">Present</div>
	</div>
	<div class="detail-item">
	<div class="detail-value">${absentDays}</div>
	<div class="detail-label">Absent</div>
	</div>
	<div class="detail-item">
	<div class="detail-value">${totalDays}</div>
	<div class="detail-label">Total Days</div>
	</div>
	</div>
	`;
	$('#attendancePercent').text(percentage + '%');
	} else {
	html = '<div class="empty-state"><i class="fas fa-chart-simple"></i><p>No attendance data for this month</p></div>';
	$('#attendancePercent').text('0%');
	}
	$('#attendanceWidget').html(html);
	})
	.fail(function(xhr, status, error) {
	console.error('Attendance API error:', error);
	console.error('Status:', status);
	console.error('Response:', xhr.responseText);
	$('#attendanceWidget').html('<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load attendance</p></div>');
	$('#attendancePercent').text('0%');
	});
	}
	function escapeHtml(str) {
	if (!str) return '';
	return str
	.replace(/&/g, '&amp;')
	.replace(/</g, '&lt;')
	.replace(/>/g, '&gt;')
	.replace(/"/g, '&quot;')
	.replace(/'/g, '&#39;');
	}
</script>