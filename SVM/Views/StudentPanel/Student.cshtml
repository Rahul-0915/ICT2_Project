@model SVM.Models.Student
@{
	ViewData["Title"] = "Dashboard";
	Layout = "~/Views/Shared/_StudentsLayout.cshtml";
}

<link rel="stylesheet"
	  href="~/css/StudentsSide_Css/Dashboard.css"
	  asp-append-version="true" />


<div class="dashboard-container">
	<!-- Welcome Banner -->
	<div class="welcome-banner">
		<h1>
			Welcome back, @Model.FirstName @Model.LastName! 👋
		</h1>
		@* <p>Roll No: @Model.RollNo | GR No: @Model.Grno</p>
		<p>Class: @ViewBag.ClassName | Section: @ViewBag.SectionName</p> *@
		<div class="current-date">
			<i class="fas fa-calendar-alt"></i>
			@DateTime.Now.ToString("dddd, MMMM dd, yyyy")
		</div>
	</div>

	<!-- Stats Cards -->
	<div class="stats-grid">
		<div class="stat-card" onclick="window.location.href='/StudentPanel/Attendance'">
			<div class="stat-info">
				<h3 id="attendancePercent">--%</h3>
				<p>Attendance</p>
			</div>
			<div class="stat-icon">
				<i class="fas fa-calendar-check"></i>
			</div>
		</div>		<div class="stat-card" onclick="window.location.href='/StudentPanel/MyTimetable'">
		<div class="stat-info">
			<h3 id="totalSubjects">--</h3>
			<p>Total Subjects</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-book-open"></i>
		</div>
	</div>
	<div class="stat-card" onclick="window.location.href='/StudentPanel/Result'">
		<div class="stat-info">
			<h3 id="resultsCount">--</h3>
			<p>Results Published</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-chart-bar"></i>
		</div>
	</div>
	<div class="stat-card" onclick="window.location.href='/StudentPanel/FeesPayment'">
		<div class="stat-info">
			<h3 id="pendingFees">₹--</h3>
			<p>Pending Fees</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-rupee-sign"></i>
		</div>
	</div>
</div>

	
	<br />

<!-- Two Column Layout -->
<div class="two-columns">

		<!-- Left Column - Notices -->
		<div class="widget-card">
			<div class="widget-header">
				<h3><i class="fas fa-bell"></i> Latest Notices</h3>
				<a href="/StudentPanel/NoticeBoard" class="view-all">View All →</a>
			</div>
			<ul class="notice-list" id="noticeList">
				<li class="empty-state">
					<i class="fas fa-spinner fa-spin"></i>
					<p>Loading notices...</p>
				</li>
			</ul>
		</div>

		<!-- Attendance Widget -->
		<div class="widget-card">
			<div class="widget-header">
				<h3><i class="fas fa-chart-line"></i> Attendance Overview</h3>
				<a href="/StudentPanel/Attendance" class="view-all">Details →</a>
			</div>
			<div class="attendance-stats" id="attendanceWidget">
				<div class="empty-state">
					<i class="fas fa-spinner fa-spin"></i>
					<p>Loading attendance...</p>
				</div>
			</div>
		</div>

		

	
</div>

<div class="two-columns">
		<!-- Latest Result Card -->
		<div id="latestResultCard" style="display: none;">
			<div class="widget-card">
				<div class="widget-header">
					<h3><i class="fas fa-trophy"></i> Latest Exam Result</h3>
					<a href="/StudentPanel/Result" class="view-all">View All →</a>
				</div>
				<div id="latestResultContent"></div>
			</div>
		</div>

		<div class="widget-card">
			<div class="widget-header">
				<h3><i class="fas fa-clock"></i> Today's Schedule</h3>
				<a href="/StudentPanel/MyTimetable" class="view-all">Full Timetable →</a>
			</div>
			<div class="timetable-preview" id="todayTimetable">
				<div class="empty-state">
					<i class="fas fa-spinner fa-spin"></i>
					<p>Loading timetable...</p>
				</div>
			</div>
		</div>
	
	</div>

</div>
<br>
