@model SVM.Models.Student
@{
	ViewData["Title"] = "Dashboard";
	Layout = "~/Views/Shared/_StudentsLayout.cshtml";
}

<style>
	.dashboard-container {
		padding: 20px;
		background: #f5f7fb;
		min-height: calc(100vh - 200px);
	}

	/* Welcome Banner */
	.welcome-banner {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 20px;
		padding: 30px;
		margin-bottom: 30px;
		color: white;
		position: relative;
		overflow: hidden;
	}

		.welcome-banner::before {
			content: "📚";
			position: absolute;
			right: -20px;
			top: -20px;
			font-size: 150px;
			opacity: 0.1;
			transform: rotate(-15deg);
		}

		.welcome-banner h1 {
			font-size: 28px;
			margin-bottom: 10px;
		}

		.welcome-banner p {
			opacity: 0.9;
			margin-bottom: 5px;
		}

	.current-date {
		font-size: 14px;
		opacity: 0.8;
		margin-top: 10px;
	}

	/* Stats Cards */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 20px;
		margin-bottom: 30px;
	}

	.stat-card {
		background: white;
		border-radius: 16px;
		padding: 20px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		box-shadow: 0 2px 8px rgba(0,0,0,0.05);
		transition: transform 0.2s, box-shadow 0.2s;
		cursor: pointer;
	}

		.stat-card:hover {
			transform: translateY(-3px);
			box-shadow: 0 8px 25px rgba(0,0,0,0.1);
		}

	.stat-info h3 {
		font-size: 28px;
		font-weight: 700;
		margin-bottom: 5px;
		color: #1e293b;
	}

	.stat-info p {
		color: #64748b;
		font-size: 14px;
		margin: 0;
	}

	.stat-icon {
		width: 55px;
		height: 55px;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 24px;
	}

	/* Two Column Layout */
	.two-columns {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 25px;
		margin-bottom: 30px;
	}

	/* Widget Cards */
	.widget-card {
		background: white;
		border-radius: 16px;
		padding: 20px;
		box-shadow: 0 2px 8px rgba(0,0,0,0.05);
	}

	.widget-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 20px;
		padding-bottom: 12px;
		border-bottom: 2px solid #f1f5f9;
	}

		.widget-header h3 {
			font-size: 18px;
			font-weight: 600;
			color: #1e293b;
			margin: 0;
		}

		.widget-header i {
			color: #667eea;
			font-size: 20px;
		}

	.view-all {
		color: #667eea;
		font-size: 13px;
		text-decoration: none;
	}

		.view-all:hover {
			text-decoration: underline;
		}

	/* Notice List */
	.notice-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.notice-item {
		padding: 12px 0;
		border-bottom: 1px solid #f1f5f9;
		display: flex;
		align-items: start;
		gap: 12px;
	}

		.notice-item:last-child {
			border-bottom: none;
		}

	.notice-icon {
		width: 32px;
		height: 32px;
		background: #fef3c7;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #f59e0b;
		font-size: 14px;
	}

	.notice-content {
		flex: 1;
	}

	.notice-title {
		font-weight: 600;
		color: #1e293b;
		margin-bottom: 4px;
		font-size: 14px;
	}

	.notice-date {
		font-size: 11px;
		color: #94a3b8;
	}

	/* Timetable Preview */
	.timetable-preview {
		overflow-x: auto;
	}

	.tt-day {
		font-weight: 600;
		color: #667eea;
		margin-bottom: 12px;
		font-size: 16px;
	}

	.tt-subject {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 10px 0;
		border-bottom: 1px solid #f1f5f9;
		font-size: 14px;
	}

		.tt-subject:last-child {
			border-bottom: none;
		}

	.subject-name {
		font-weight: 500;
		color: #1e293b;
	}

	.subject-time {
		color: #94a3b8;
		font-size: 12px;
		background: #f8fafc;
		padding: 4px 8px;
		border-radius: 12px;
	}

	/* Quick Actions */
	.quick-actions-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
	}

	.quick-action-btn {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 14px;
		text-align: center;
		text-decoration: none;
		transition: all 0.2s;
	}

		.quick-action-btn:hover {
			background: #667eea;
			border-color: #667eea;
			transform: translateY(-2px);
		}

		.quick-action-btn i {
			font-size: 24px;
			color: #667eea;
			margin-bottom: 8px;
			display: block;
		}

		.quick-action-btn:hover i,
		.quick-action-btn:hover span {
			color: white;
		}

		.quick-action-btn span {
			font-size: 13px;
			color: #1e293b;
		}

	/* Attendance Ring */
	.attendance-stats {
		text-align: center;
		padding: 10px;
	}

	.attendance-ring {
		position: relative;
		width: 150px;
		height: 150px;
		margin: 0 auto 20px;
	}

	.ring-bg {
		fill: none;
		stroke: #e2e8f0;
		stroke-width: 10;
	}

	.ring-progress {
		fill: none;
		stroke: #667eea;
		stroke-width: 10;
		stroke-linecap: round;
		transition: stroke-dasharray 0.5s ease;
	}

	.attendance-percent {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		text-align: center;
	}

		.attendance-percent .percent {
			font-size: 28px;
			font-weight: 700;
			color: #1e293b;
		}

		.attendance-percent .label {
			font-size: 12px;
			color: #64748b;
		}

	.attendance-detail {
		display: flex;
		justify-content: center;
		gap: 20px;
		margin-top: 15px;
	}

	.detail-item {
		text-align: center;
	}

	.detail-value {
		font-size: 18px;
		font-weight: 700;
		color: #1e293b;
	}

	.detail-label {
		font-size: 11px;
		color: #64748b;
	}

	/* Empty State */
	.empty-state {
		text-align: center;
		padding: 40px 20px;
		color: #94a3b8;
	}

		.empty-state i {
			font-size: 48px;
			margin-bottom: 15px;
			opacity: 0.5;
		}

	/* Latest Result Card */
	.result-card {
		background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
		margin-bottom: 25px;
	}

	.result-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 15px;
	}

	.result-exam-name {
		font-size: 14px;
		color: #92400e;
		margin-bottom: 5px;
	}

	.result-percentage {
		font-size: 32px;
		font-weight: 700;
	}

	.result-pass {
		color: #059669;
	}

	.result-fail {
		color: #dc2626;
	}

	.result-status {
		font-size: 13px;
		margin-top: 5px;
	}

	.result-marks {
		text-align: right;
	}

	.result-marks-label {
		font-size: 13px;
		color: #92400e;
	}

	.result-marks-value {
		font-size: 24px;
		font-weight: 700;
		color: #1e293b;
	}
</style>

<div class="dashboard-container">
	<!-- Welcome Banner -->
	<div class="welcome-banner">
		<h1>
			Welcome back, @Model.FirstName @Model.LastName! 👋
		</h1>
		<p>Roll No: @Model.RollNo | GR No: @Model.Grno</p>
		<p>Class: @ViewBag.ClassName | Section: @ViewBag.SectionName</p>
		<div class="current-date">
			<i class="fas fa-calendar-alt"></i>
			@DateTime.Now.ToString("dddd, MMMM dd, yyyy")
		</div>
	</div>

	<!-- Stats Cards -->
	<div class="stats-grid">
		<div class="stat-card" onclick="window.location.href='/StudentPanel/Attendance'">
			<div class="stat-info">
				<h3 id="attendancePercent">--%</h3>
				<p>Attendance</p>
			</div>
			<div class="stat-icon">
				<i class="fas fa-calendar-check"></i>
			</div>
		</div>		<div class="stat-card" onclick="window.location.href='/StudentPanel/MyTimetable'">
		<div class="stat-info">
			<h3 id="totalSubjects">--</h3>
			<p>Subjects</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-book-open"></i>
		</div>
	</div>
	<div class="stat-card" onclick="window.location.href='/StudentPanel/Result'">
		<div class="stat-info">
			<h3 id="resultsCount">--</h3>
			<p>Results Published</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-chart-bar"></i>
		</div>
	</div>
	<div class="stat-card" onclick="window.location.href='/StudentPanel/FeesPayment'">
		<div class="stat-info">
			<h3 id="pendingFees">₹--</h3>
			<p>Pending Fees</p>
		</div>
		<div class="stat-icon">
			<i class="fas fa-rupee-sign"></i>
		</div>
	</div>
</div>

<!-- Latest Result Card -->
<div id="latestResultCard" style="display: none;">
	<div class="widget-card result-card">
		<div class="widget-header">
			<h3><i class="fas fa-trophy"></i> Latest Exam Result</h3>
			<a href="/StudentPanel/Result" class="view-all">View All →</a>
		</div>
		<div id="latestResultContent"></div>
	</div>
</div>

<!-- Two Column Layout -->
<div class="two-columns">
	<!-- Left Column - Notices -->
	<div class="widget-card">
		<div class="widget-header">
			<h3><i class="fas fa-bell"></i> Latest Notices</h3>
			<a href="/StudentPanel/NoticeBoard" class="view-all">View All →</a>
		</div>
		<ul class="notice-list" id="noticeList">
			<li class="empty-state">
				<i class="fas fa-spinner fa-spin"></i>
				<p>Loading notices...</p>
			</li>
		</ul>
	</div>

	<!-- Right Column - Today's Schedule -->
	<div class="widget-card">
		<div class="widget-header">
			<h3><i class="fas fa-clock"></i> Today's Schedule</h3>
			<a href="/StudentPanel/MyTimetable" class="view-all">Full Timetable →</a>
		</div>
		<div class="timetable-preview" id="todayTimetable">
			<div class="empty-state">
				<i class="fas fa-spinner fa-spin"></i>
				<p>Loading timetable...</p>
			</div>
		</div>
	</div>
</div>

<div class="two-columns">
	<!-- Attendance Widget -->
	<div class="widget-card">
		<div class="widget-header">
			<h3><i class="fas fa-chart-line"></i> Attendance Overview</h3>
			<a href="/StudentPanel/Attendance" class="view-all">Details →</a>
		</div>
		<div class="attendance-stats" id="attendanceWidget">
			<div class="empty-state">
				<i class="fas fa-spinner fa-spin"></i>
				<p>Loading attendance...</p>
			</div>
		</div>
	</div>

	<!-- Quick Actions -->
	<div class="widget-card">
		<div class="widget-header">
			<h3><i class="fas fa-bolt"></i> Quick Actions</h3>
		</div>
		<div class="quick-actions-grid">
			<a href="/StudentPanel/DigitalICard" class="quick-action-btn">
				<i class="fas fa-id-card"></i>
				<span>ID Card</span>
			</a>
			<a href="/StudentPanel/FeesPayment" class="quick-action-btn">
				<i class="fas fa-rupee-sign"></i>
				<span>Pay Fees</span>
			</a>
			<a href="/StudentPanel/Result" class="quick-action-btn">
				<i class="fas fa-chart-bar"></i>
				<span>Results</span>
			</a>
			<a href="/StudentPanel/MyProfile" class="quick-action-btn">
				<i class="fas fa-user-edit"></i>
				<span>Profile</span>
			</a>
		</div>
	</div>
</div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	$(document).ready(function() {
	loadDashboardData();
	});

	function loadDashboardData() {
	// Load Notices
	$.get('/StudentPanel/GetActiveNotices')
	.done(function(notices) {
	var noticeHtml = '';
	if (notices && notices.length > 0) {
	notices.slice(0, 5).forEach(function(notice) {
	var date = notice.createdAt ? new Date(notice.createdAt) : new Date();
	noticeHtml += `
	<li class="notice-item">
	<div class="notice-icon">
	<i class="fas fa-bullhorn"></i>
	</div>
	<div class="notice-content">
	<div class="notice-title">${escapeHtml(notice.title || 'Notice')}</div>
	<div class="notice-date">${date.toLocaleDateString()}</div>
	</div>
	</li>
	`;
	});
	} else {
	noticeHtml = '<li class="empty-state"><i class="fas fa-inbox"></i><p>No notices available</p></li>';
	}
	$('#noticeList').html(noticeHtml);
	})
	.fail(function() {
	$('#noticeList').html('<li class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load notices</p></li>');
	});

	// Load Today's Timetable
	loadTodayTimetable();

	// Load Attendance
	loadAttendance();

	// Load Subjects Count
	$.get('/StudentPanel/GetSubjectsCount')
	.done(function(data) {
	$('#totalSubjects').text(data.count || '0');
	})
	.fail(function() {
	$('#totalSubjects').text('0');
	});

	// Load Results Count (Published Results)
	$.get('/StudentPanel/GetPublishedResultsCount')
	.done(function(data) {
	$('#resultsCount').text(data.count || '0');
	})
	.fail(function() {
	$('#resultsCount').text('0');
	});

	// Load Latest Exam Result
	$.get('/StudentPanel/GetLatestExamResult')
	.done(function(data) {
	if (data.hasResult) {
	$('#latestResultCard').show();
	var percentageColor = data.result === 'Pass' ? '#059669' : '#dc2626';
	var percentageClass = data.result === 'Pass' ? 'result-pass' : 'result-fail';

	$('#latestResultContent').html(`
	<div class="result-content">
	<div>
	<div class="result-exam-name">${escapeHtml(data.examName)}</div>
	<div class="result-percentage ${percentageClass}">${data.percentage}%</div>
	<div class="result-status">Result: ${data.result}</div>
	</div>
	<div class="result-marks">
	<div class="result-marks-label">Marks Obtained</div>
	<div class="result-marks-value">${data.totalObtained} / ${data.totalMax}</div>
	</div>
	</div>
	`);
	} else {
	$('#latestResultCard').hide();
	}
	})
	.fail(function() {
	$('#latestResultCard').hide();
	});

	// Load Pending Fees
	$.get('/StudentPanel/GetPendingFees')
	.done(function(data) {
	var amount = data.amount || 0;
	$('#pendingFees').text('₹' + amount.toLocaleString());
	})
	.fail(function() {
	$('#pendingFees').text('₹0');
	});
	}

	function loadTodayTimetable() {
	$.get('/StudentPanel/GetTodayTimetable')
	.done(function(data) {
	var html = '';
	if (data && data.length > 0) {
	var today = new Date().toLocaleDateString('en-US', { weekday: 'long' });
	html = `<div class="tt-day">📅 ${today}</div>`;
	data.forEach(function(subject) {
	html += `
	<div class="tt-subject">
	<span class="subject-name">${escapeHtml(subject.subjectName)}</span>
	<span class="subject-time">${subject.startTime} - ${subject.endTime}</span>
	</div>
	`;
	});
	} else {
	html = '<div class="empty-state"><i class="fas fa-calendar-day"></i><p>No classes scheduled for today</p></div>';
	}
	$('#todayTimetable').html(html);
	})
	.fail(function() {
	$('#todayTimetable').html('<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load timetable</p></div>');
	});
	}

	function loadAttendance() {
	console.log('Fetching attendance summary...');

	$.get('/StudentPanel/GetAttendanceSummary')
	.done(function(data) {
	console.log('Attendance Summary Response:', data);
	var html = '';

	// Check if we have valid attendance data
	if (data && data.percentage > 0) {
	var percentage = data.percentage;
	var presentDays = data.present;
	var absentDays = data.absent;
	var totalDays = presentDays + absentDays;

	console.log('Present Days:', presentDays, 'Absent Days:', absentDays, 'Total Days:', totalDays, 'Percentage:', percentage);

	var circumference = 2 * Math.PI * 65;
	var dashArray = (percentage / 100) * circumference;

	// If dashArray is 0, set a tiny value to still show the ring
	if (dashArray === 0 && percentage === 0) {
	dashArray = 1;
	}

	html = `
	<div class="attendance-ring">
	<svg width="150" height="150" viewBox="0 0 150 150">
	<circle cx="75" cy="75" r="65" class="ring-bg" />
	<circle cx="75" cy="75" r="65" class="ring-progress"
	stroke-dasharray="${dashArray} ${circumference}"
	transform="rotate(-90 75 75)" />
	</svg>
	<div class="attendance-percent">
	<div class="percent">${percentage}%</div>
	<div class="label">Attendance</div>
	</div>
	</div>
	<div class="attendance-detail">
	<div class="detail-item">
	<div class="detail-value">${presentDays}</div>
	<div class="detail-label">Present</div>
	</div>
	<div class="detail-item">
	<div class="detail-value">${absentDays}</div>
	<div class="detail-label">Absent</div>
	</div>
	<div class="detail-item">
	<div class="detail-value">${totalDays}</div>
	<div class="detail-label">Total Days</div>
	</div>
	</div>
	`;
	$('#attendancePercent').text(percentage + '%');
	} else {
	html = '<div class="empty-state"><i class="fas fa-chart-simple"></i><p>No attendance data for this month</p></div>';
	$('#attendancePercent').text('0%');
	}
	$('#attendanceWidget').html(html);
	})
	.fail(function(xhr, status, error) {
	console.error('Attendance API error:', error);
	console.error('Status:', status);
	console.error('Response:', xhr.responseText);
	$('#attendanceWidget').html('<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load attendance</p></div>');
	$('#attendancePercent').text('0%');
	});
	}
	function escapeHtml(str) {
	if (!str) return '';
	return str
	.replace(/&/g, '&amp;')
	.replace(/</g, '&lt;')
	.replace(/>/g, '&gt;')
	.replace(/"/g, '&quot;')
	.replace(/'/g, '&#39;');
	}
</script>