<div class="dashboard-container">

	<div class="student-card">

		<img src="@Model.StudentPhoto" class="student-photo" />
		@{
			string fatherName = Model.FatherName ?? "";
			string lastName = Model.LastName ?? "";

			if (fatherName.EndsWith(lastName, StringComparison.OrdinalIgnoreCase))
			{
				fatherName = fatherName.Substring(0, fatherName.Length - lastName.Length).Trim();
			}
		}

		<h2>
			@Model.FirstName @fatherName @Model.LastName
		</h2>


	</div>

	<div class="menu-grid">

		<a href="#" class="menu-box">
			<i class="fa-solid fa-house"></i>
			<span>Student Dashboard</span>
		</a>

		<a asp-controller="StudentPanel"
		   asp-action="DigitalICard"
		   class="menu-box">
			<i class="fa-solid fa-id-card"></i>
			<span>Digital I-Card</span>
		</a>

	</div>

</div>
