@model StudentAttendanceVM
@{
    Layout = "~/Views/Shared/_StudentsLayout.cshtml";
    // Get current date for comparison
    var currentDate = DateTime.Now;
    var displayYear = ViewBag.Year ?? currentDate.Year;
    var displayMonth = ViewBag.Month ?? currentDate.Month;
    var monthName = new DateTime(displayYear, displayMonth, 1).ToString("MMMM");
}

<link rel="stylesheet"
      href="~/css/StudentsSide_Css/attendance.css"
      asp-append-version="true" />

<style>
    .attendance-box {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .monthly-attendance-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
    }

        .monthly-attendance-header h2 {
            margin: 0;
            color: #1e293b;
            font-size: 24px;
        }

    .month-nav {
        display: flex;
        gap: 15px;
        align-items: center;
    }

        .month-nav a {
            text-decoration: none;
            background: #667eea;
            color: white;
            padding: 8px 15px;
            border-radius: 8px;
            font-weight: bold;
            transition: background 0.2s;
        }

            .month-nav a:hover {
                background: #5a67d8;
            }

        .month-nav span {
            font-size: 18px;
            font-weight: 600;
            color: #1e293b;
            min-width: 150px;
            text-align: center;
        }

    .current-month-badge {
        background: #10b981;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        margin-left: 10px;
    }

    .summary {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .box {
        background: white;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.2s;
    }

        .box:hover {
            transform: translateY(-3px);
        }

        .box h3 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .box p {
            color: #64748b;
            font-size: 14px;
            margin: 0;
        }

    .present-box h3 {
        color: #10b981;
    }

    .absent-box h3 {
        color: #ef4444;
    }

    .total-box h3 {
        color: #3b82f6;
    }

    .percent-box h3 {
        color: #8b5cf6;
    }

    .legend {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-bottom: 25px;
        padding: 15px;
        background: #f8fafc;
        border-radius: 12px;
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

    .present-dot {
        background: #10b981;
    }

    .absent-dot {
        background: #ef4444;
    }

    .calendar {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
        margin-bottom: 30px;
        background: white;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .day {
        text-align: center;
        padding: 12px 8px;
        border-radius: 8px;
        font-weight: 500;
        transition: transform 0.2s;
    }

        .day.present {
            background: #d1fae5;
            color: #065f46;
        }

        .day.absent {
            background: #fee2e2;
            color: #991b1b;
        }

    table {
        width: 70%;
        margin:auto;
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    th {
        background: #f8fafc;
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #1e293b;
    }

    td {
        padding: 12px 15px;
        border-bottom: 1px solid #e2e8f0;
    }

    .badge-present {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-absent {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .no-data {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
    }

        .no-data i {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.5;
        }
</style>

<div class="attendance-box">
    <!-- HEADER -->
    <div class="monthly-attendance-header">
        <h2>
            Monthly Attendance
            @if (displayYear == currentDate.Year && displayMonth == currentDate.Month)
            {
                <span class="current-month-badge">Current Month</span>
            }
        </h2>
        <div class="month-nav">
            <a href="@Url.Action("Attendance", new { year = displayMonth == 1 ? displayYear - 1 : displayYear, month = displayMonth == 1 ? 12 : displayMonth - 1 })">
                ◀
            </a>
            <span>@monthName @displayYear</span>
            <a href="@Url.Action("Attendance", new { year = displayMonth == 12 ? displayYear + 1 : displayYear, month = displayMonth == 12 ? 1 : displayMonth + 1 })">
                ▶
            </a>
        </div>
    </div>

    @if (Model?.Students != null && Model.Students.Any() && Model.TotalDays > 0)
    {
        var s = Model.Students.First();

        <!-- SUMMARY -->
        <div class="summary">
            <div class="box present-box">
                <h3>@s.Present</h3>
                <p>Present Days</p>
            </div>
            <div class="box absent-box">
                <h3>@s.Absent</h3>
                <p>Absent Days</p>
            </div>
            <div class="box total-box">
                <h3>@Model.TotalDays</h3>
                <p>Total Days</p>
            </div>
            <div class="box percent-box">
                <h3>@s.Percentage%</h3>
                <p>Attendance Percentage</p>
            </div>
        </div>

        <!-- LEGEND -->
        <div class="legend">
            <span><span class="dot present-dot"></span>Present</span>
            <span><span class="dot absent-dot"></span>Absent</span>
        </div>

        <!-- CALENDAR -->
        @* <div class="calendar">
            @{
                string[] weekDays = { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };
            }
            @foreach (var day in weekDays)
            {
                <div style="text-align: center; font-weight: 700; color: #64748b; padding: 8px;">
                    @day
                </div>
            }
            @foreach (var d in Model.Dates)
            {
                var st = s.DailyStatus.FirstOrDefault(x => x.Date.Date == d.Date);
                string cls = (st?.Status == "P") ? "present" : "absent";

                <div class="day @cls">
                    @d.Day
                </div>
            }
        </div> *@

        <!-- TABLE -->
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Day</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Dates)
                {
                    var st = s.DailyStatus.FirstOrDefault(x => x.Date.Date == d.Date);
                    <tr>
                        <td>@d.ToString("dd MMM yyyy")</td>
                        <td>@d.ToString("dddd")</td>
                        <td>
                            @if (st?.Status == "P")
                            {
                                <span class="badge-present">✓ Present</span>
                            }
                            else
                            {
                                <span class="badge-absent">✗ Absent</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="no-data">
            <i class="fas fa-chart-line"></i>
            <p>No attendance data found for @monthName @displayYear</p>
            @if (displayYear != currentDate.Year || displayMonth != currentDate.Month)
            {
                <a href="@Url.Action("Attendance")" class="view-all" style="display: inline-block; margin-top: 15px;">
                    View Current Month →
                </a>
            }
        </div>
    }
</div>