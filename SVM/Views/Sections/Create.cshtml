@model SVM.Models.Section

@{
    ViewData["Title"] = "Create Section";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/AdminSide_Css/Forms.css" asp-append-version="true" />
    <title>Create Section</title>
</head>

<body>

    <div class="session-page">

        <div class="session-card">

            <h3 class="card-title">Add Section</h3>

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-grid">

                    <!-- MEDIUM -->
                    <div class="form-group">
                        <label>Medium</label>

                        <select id="Medium" class="form-control">
                            <option value="">-- Select Medium --</option>
                            <option value="Gujarati" selected="@(ViewBag.SelectedMedium == "Gujarati")">Gujarati</option>
                            <option value="English" selected="@(ViewBag.SelectedMedium == "English")">English</option>
                        </select>
                    </div>

                    <!-- CLASS -->
                    <div class="form-group">
                        <label>Select Class</label>

                        <select asp-for="ClassId"
                                id="ClassId"
                                class="form-control">

                            <option value="">-- Select Class --</option>

                        </select>

                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>

                    <!-- SECTION NAME -->
                    <div class="form-group">
                        <label>Section Name</label>

                        <input asp-for="SectionName"
                               class="form-control"
                               placeholder="Enter A, B, C..." />

                        <span asp-validation-for="SectionName" class="text-danger"></span>
                    </div>

                </div>

                <!-- BUTTONS (same as Class form) -->
                <div style="display:flex; gap:15px; flex-wrap:wrap;">

                    <input type="submit" value="Create" class="create-btn" />

                    <a asp-controller="Classes" asp-action="Index">
                        <button type="button" class="Back-btn">← Back to List</button>
                    </a>

                </div>

            </form>

        </div>

    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

            var selectedClassId = '@ViewBag.SelectedClassId';

            $('#Medium').change(function () {

                var medium = $(this).val();
                var ddl = $('#ClassId');

                if (medium === '') {
                    ddl.html('<option value="">-- Select Class --</option>');
                    return;
                }

                ddl.html('<option>Loading...</option>');

                $.ajax({
                    url: '/Sections/GetClassesByMedium',
                    type: 'GET',
                    data: { medium: medium },

                    success: function (data) {

                        ddl.empty();
                        ddl.append('<option value="">-- Select Class --</option>');

                        $.each(data, function (i, item) {

                            var selected = item.value == selectedClassId ? 'selected' : '';

                            ddl.append('<option value="' + item.value + '" ' + selected + '>' + item.text + '</option>');

                        });

                    },

                    error: function () {
                        ddl.html('<option>Error loading classes</option>');
                    }
                });
            });

            if ($('#Medium').val() !== '') {
                $('#Medium').trigger('change');
            }

        });
    </script>

</body>
</html>