@model SVM.Models.Section

@{
    ViewData["Title"] = "Delete Section";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />

<!DOCTYPE html>
<html>
<head>
    <title>Delete Section</title>
</head>
<body>
    <div class="container">
        <h1>Delete Section</h1>
        <hr />
        
        <div>
            <h4>Section Information</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.SectionName)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.SectionName)
                </dd>
                <dt class="col-sm-2">
                    Class
                </dt>
                <dd class="col-sm-10">
                    @if (Model.Class != null)
                    {
                        @($"{Model.Class.ClassName} - {Model.Class.Medium}")
                    }
                    else
                    {
                        <span class="text-muted">N/A</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="SectionId" />
                <div class="form-actions">
                    <input type="submit" value="Delete" class="btn btn-danger" />
                    <a asp-controller="Classes"
                       asp-action="Index"
                       asp-route-medium="@ViewBag.CurrentMedium"
                       asp-route-classId="@ViewBag.CurrentClassId"
                       class="btn btn-secondary">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>