@using Microsoft.AspNetCore.Http

@{
    Layout = null;
}



<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Student Portal</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet"
          href="~/css/StudentsSide_Css/Navbar.css"
          asp-append-version="true" />

</head>
<body>
    <header>

        <div class="header">

            <div class="logo">
                <img src="/images/svmGuj_Logo.png" />

                <div class="logo-text">
                    <h2>S.V.M</h2>
                    <span>EXCELLENCE IN EDUCATION</span>
                </div>
            </div>
        <div class="student-box">

           
                <div class="student-btn">
                    <i class="fas fa-user-graduate"></i>
                    <span>@Context.Session.GetString("FullName")</span>
                    <i class="fas fa-chevron-down"></i>
                </div>

            <div class="dropdown">

                <a href="#">
                    <i class="fa fa-user"></i>
                    My Profile
                </a>

                <a asp-controller="UserHome" asp-action="UserHome">
                    <i class="fa fa-sign-out-alt"></i>
                    Logout
                </a>

            </div>
        </div>

        </div>
        <nav class="main-navbar">

            <button class="menu-toggle" type="button">
                <i class="fas fa-bars"></i>
            </button>

            <ul class="nav-menu">

                <li>
                    <a href="#">
                        <i class="fas fa-house"></i>
                        Dashboard
                    </a>
                </li>

                <li class="has-submenu">

                    <a href="javascript:void(0)">
                        <span>
                            <i class="fas fa-graduation-cap"></i>
                            Academic
                        </span>

                        <i class="fas fa-chevron-down nav-arrow"></i>
                    </a>

                    <ul class="submenu">
                        <li><a href="#">Attendance</a></li>
                        <li><a href="#">Result</a></li>
                        <li><a href="#">Progress Report</a></li>
                    </ul>

                </li>

                <li class="has-submenu">

                    <a href="javascript:void(0)">
                        <span>
                            <i class="fas fa-book"></i>
                            Study
                        </span>

                        <i class="fas fa-chevron-down nav-arrow"></i>
                    </a>

                    <ul class="submenu">
                        <li><a href="#">Homework</a></li>
                        <li><a href="#">Assignments</a></li>
                        <li><a href="#">Notes</a></li>
                    </ul>

                </li>

                <li><a href="#">Timetable</a></li>
                <li><a href="#">Notice Board</a></li>
                <li><a href="#">Gallery</a></li>

            </ul>

        </nav>
     
    </header>




    <!-- PAGE BODY -->

    <main class="page-wrapper">

        @RenderBody()

    </main>

  

</body>
</html>
<script>

    const menuBtn = document.querySelector(".menu-toggle");
    const navMenu = document.querySelector(".nav-menu");

    /* Mobile Main Menu */

    menuBtn.addEventListener("click", function () {

        navMenu.classList.toggle("active");

        /* submenu close when menu close */
        if (!navMenu.classList.contains("active")) {
            document.querySelectorAll(".has-submenu").forEach(x => {
                x.classList.remove("open");
            });
        }
    });


    /* Mobile Submenu */

    document.querySelectorAll(".has-submenu > a").forEach(item => {

        item.addEventListener("click", function (e) {

            if (window.innerWidth <= 768) {

                e.preventDefault();

                const parent = this.parentElement;

                if (parent.classList.contains("open")) {

                    parent.classList.remove("open");
                    return;
                }

                document.querySelectorAll(".has-submenu").forEach(x => {
                    x.classList.remove("open");
                });

                parent.classList.add("open");
            }
        });

    });


    /* Student Profile Dropdown Mobile */

    const studentBtn = document.querySelector(".student-btn");
    const dropdown = document.querySelector(".dropdown");

    studentBtn.addEventListener("click", function (e) {

        if (window.innerWidth <= 768) {

            e.stopPropagation();

            dropdown.classList.toggle("show");
        }
    });

    document.addEventListener("click", function () {

        if (window.innerWidth <= 768) {

            dropdown.classList.remove("show");
        }
    });

</script>