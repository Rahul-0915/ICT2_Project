		<script src="@Url.Content("~/js/UserSide_Js/UserScript.js")"></script>
		@RenderSection("Scripts", required: false)

	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
	<script>

		$(function () {

			// NOTICE BADGE - DATE BASED TRACKING
			function updateNoticeBadge() {
				$.get('/UserHome/GetPublicNotices', function (notices) {

					if (!notices || notices.length === 0) {
						$("#publicNoticeBadge").hide();
						return;
					}

					// Last read timestamp from localStorage
					let lastReadStr = localStorage.getItem("PublicNoticeLastRead");
					let lastReadDate = lastReadStr ? new Date(lastReadStr) : null;

					// Count unread notices
					let unreadCount = 0;

					for (let i = 0; i < notices.length; i++) {
						let noticeDate = new Date(notices[i].createdAt);

						if (lastReadDate === null) {
							unreadCount = notices.length;
							break;
						}

						if (noticeDate > lastReadDate) {
							unreadCount++;
						}
					}

					if (unreadCount > 0) {
						$("#publicNoticeBadge")
							.text(unreadCount)
							.show();
					} else {
						$("#publicNoticeBadge").hide();
					}
				});
			}

			// MARK AS READ - jab notice page open kare
			function markNoticesAsRead() {
				$.get('/UserHome/GetPublicNotices', function (notices) {
					if (notices && notices.length > 0) {
						let latestDate = null;
						for (let i = 0; i < notices.length; i++) {
							let noticeDate = new Date(notices[i].createdAt);
							if (latestDate === null || noticeDate > latestDate) {
								latestDate = noticeDate;
							}
						}

						if (latestDate) {
							localStorage.setItem("PublicNoticeLastRead", latestDate.toISOString());
							$("#publicNoticeBadge").hide();
						}
					}
				});
			}

			// Initial badge update
			updateNoticeBadge();

			// Agar Notice page pe ho toh mark as read
			if (window.location.pathname.toLowerCase().includes('notice')) {
				markNoticesAsRead();
			}

			// Notice link click pe badge clear
			$('a[href*="Notice"]').on('click', function () {
				setTimeout(function () {
					markNoticesAsRead();
				}, 500);
			});

			// Har 1 minute me badge refresh
			setInterval(updateNoticeBadge, 60000);
		});

	</script>
	</body>
	</html>