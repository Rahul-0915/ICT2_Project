@model IEnumerable<SVM.Models.Staff>

@{
    ViewData["Title"] = "Staff List";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@* @if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
} *@

<link rel="stylesheet" href="~/css/List.css" asp-append-version="true" />

<p>
    <a asp-action="Create" class="btn-add">+</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Photo</th>
            <th>Full Name</th>
            <th>Designation</th>
            <th>Phone</th>
            <th>Joining Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <!-- Circular staff photo -->
                <td>
                    @if (!string.IsNullOrEmpty(item.StafPhoto))
                    {
                        <img src="@item.StafPhoto" alt="Staff Photo"
                             style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%; border: 1px solid #ddd;" />
                    }
                    else
                    {
                        <div style="width: 50px; height: 50px; background-color: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #aaa;">
                            📷
                        </div>
                    }
                </td>
                <!-- Full name (combined) -->
                <td>@Html.DisplayFor(modelItem => item.FirstName) @Html.DisplayFor(modelItem => item.LastName)</td>
                <td>@Html.DisplayFor(modelItem => item.Designation)</td>
                <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                <td>@(item.JoiningDate.HasValue? item.JoiningDate.Value.ToString("dd-MM-yyyy") : "")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.StaffId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.StaffId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.StaffId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>