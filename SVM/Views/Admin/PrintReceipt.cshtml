@{
    Layout = null;
    var receipt = ViewBag.Receipt as dynamic;
    var feeStructure = ViewBag.FeeStructure as dynamic;

    // Get medium from student's class (Tumhare logic ke hisaab se)
    var medium = ViewBag.Medium as string ?? "Gujarati";

    // School Details based on Medium - Tumhare Student Details wale logic ke hisaab se
    var schoolName = medium == "English" ? "S.V.M ENGLISH MEDIUM" : "શારદા વિદ્યામંદિર";
    var logoPath = medium == "English" ? "/images/SVMEng_logo.png" : "/images/SVMGuj_logo.png";

    // School Address (Fixed for both mediums)
    var schoolAddress = "Gujarat Housing Board, Pandesara, Surat - 394221";
    var schoolPhone = "+91 9876543210";
    var schoolEmail = "shardavidhyamandir@gmail.com";

    // Format date
    var paymentDate = DateTime.Now;
    var dateFormatted = paymentDate.ToString("dd-MM-yyyy");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Fee Receipt</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/AdminSide_Css/PrintReceipt.css" asp-append-version="true" />
</head>
<body>
    <div class="receipt-page">
        <div class="top-actions no-print">
            <button type="button" class="print-btn" onclick="window.print()">
                <i class="fa-solid fa-print"></i> Print / Save as PDF
            </button>
            <button type="button" class="close-btn" onclick="window.close()">
                <i class="fa-solid fa-times"></i> Close
            </button>
        </div>

        <div class="receipt-container">
            <!-- HEADER WITH SCHOOL DETAILS -->
            <div class="receipt-header">
                <div class="logo-box">
                    <img src="@logoPath" alt="School Logo" />
                </div>
                <div class="school-details">
                    <h1 class="school-name">@schoolName</h1>
                    <p>@schoolAddress</p>
                    <p>📞 @schoolPhone &nbsp; | &nbsp; ✉️ @schoolEmail</p>
                </div>
            </div>

            <!-- RECEIPT TITLE -->
            <div class="receipt-title">
                FEE RECEIPT
            </div>

            <!-- STUDENT & RECEIPT INFO -->
            <div class="info-section">
                <div class="info-row">
                    <span class="label">Receipt No.</span>
                    <span class="value">#@receipt?.receiptNo</span>
                </div>
                <div class="info-row">
                    <span class="label">Date</span>
                    <span class="value">@dateFormatted</span>
                </div>
                <div class="info-row">
                    <span class="label">Student Name</span>
                    <span class="value">@receipt?.studentName</span>
                </div>
                <div class="info-row">
                    <span class="label">Class</span>
                    <span class="value">@receipt?.className</span>
                </div>
                <div class="info-row">
                    <span class="label">Section</span>
                    <span class="value">@receipt?.sectionName</span>
                </div>
            </div>

            <!-- FEE STRUCTURE TABLE -->
            <div class="section-title">FEE DETAILS</div>
            <table class="fee-table">
                <thead>
                    <tr>
                        <th>Sr. No.</th>
                        <th>Particulars</th>
                        <th>Amount (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (feeStructure != null)
                    {
                        int sr = 1;
                        if (feeStructure.AdmissionFees != null && feeStructure.AdmissionFees > 0)
                        {
                            <tr>
                                <td>@sr</td>
                                <td>Admission Fees</td>
                                <td class="text-right">₹@feeStructure.AdmissionFees?.ToString("N2")</td>
                            </tr>
                            sr++;
                        }
                        if (feeStructure.MonthlyFees != null && feeStructure.MonthlyFees > 0)
                        {
                            <tr>
                                <td>@sr</td>
                                <td>Monthly Fees (12 Months)</td>
                                <td class="text-right">₹@((feeStructure.MonthlyFees * 12)?.ToString("N2"))</td>
                            </tr>
                            sr++;
                        }
                        if (feeStructure.ComputerFees != null && feeStructure.ComputerFees > 0)
                        {
                            <tr>
                                <td>@sr</td>
                                <td>Computer Fees</td>
                                <td class="text-right">₹@feeStructure.ComputerFees?.ToString("N2")</td>
                            </tr>
                            sr++;
                        }
                        if (feeStructure.OtherActivityFees != null && feeStructure.OtherActivityFees > 0)
                        {
                            <tr>
                                <td>@sr</td>
                                <td>Other Activity Fees</td>
                                <td class="text-right">₹@feeStructure.OtherActivityFees?.ToString("N2")</td>
                            </tr>
                            sr++;
                        }
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2" class="text-right"><strong>Total Amount</strong></td>
                        <td class="text-right"><strong>₹@receipt?.amountPaid?.ToString("N2")</strong></td>
                    </tr>
                </tfoot>
            </table>

            <!-- PAYMENT DETAILS -->
            <div class="section-title">PAYMENT DETAILS</div>
            <div class="payment-details">
                <div class="payment-row">
                    <span class="label">Payment Mode</span>
                    <span class="value">💵 @receipt?.paymentMode</span>
                </div>
                <div class="payment-row">
                    <span class="label">Transaction ID</span>
                    <span class="value">@receipt?.transactionId</span>
                </div>
                <div class="payment-row">
                    <span class="label">Payment Date</span>
                    <span class="value">@paymentDate.ToString("dd MMM yyyy, hh:mm tt")</span>
                </div>
                <div class="payment-row">
                    <span class="label">Amount Paid</span>
                    <span class="value amount">₹@receipt?.amountPaid?.ToString("N2")</span>
                </div>
            </div>

            <!-- AMOUNT IN WORDS -->
            <div class="amount-box">
                <label>Amount in Words</label>
                <div class="amount-in-words">
                    @NumberToWords((long)(receipt?.amountPaid ?? 0)) Rupees Only
                </div>
            </div>

            <!-- FOOTER -->
            <div class="receipt-footer">
                <div class="signature">
                    <div class="signature-box">
                        <span>For @schoolName</span>
                        <div class="sign-line">Authorized Signatory</div>
                    </div>
                    <div class="signature-box">
                        <span>Student/Parent Signature</span>
                        <div class="sign-line"></div>
                    </div>
                </div>
                <div class="generated-text">
                    
                    <p>This is a computer generated receipt. No signature required.</p>
                    <p>You can download the complete fee structure from the Student Dashboard at SVM.org</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

@functions {
    // Convert number to words
    public string NumberToWords(long number)
    {
        if (number == 0) return "Zero";

        string[] ones = { "", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine" };
        string[] teens = { "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen" };
        string[] tens = { "", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety" };
        string[] thousands = { "", "Thousand", "Million", "Billion" };

        string words = "";

        for (int i = 0; number > 0; i++)
        {
            if (number % 1000 != 0)
            {
                words = ConvertHundreds(number % 1000, ones, teens, tens) + " " + thousands[i] + " " + words;
            }
            number /= 1000;
        }

        return words.Trim();

        string ConvertHundreds(long num, string[] onesArr, string[] teensArr, string[] tensArr)
        {
            if (num == 0) return "";
            if (num < 10) return onesArr[num];
            if (num < 20) return teensArr[num - 10];
            if (num < 100) return tensArr[num / 10] + " " + onesArr[num % 10];
            return onesArr[num / 100] + " Hundred " + ConvertHundreds(num % 100, onesArr, teensArr, tensArr);
        }
    }
}