@{
	Layout = null;
}

<!DOCTYPE html>
<html>

<head>
	<title>S.V.M Admin Panel</title>
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="~/css/AdminPanel.css" asp-append-version="true" />
</head>

<body>

	<!-- HEADER -->
	<div class="header">

		<div class="logo">

			<img src="/images/svmGuj_Logo.png"
				 alt="SVM Logo"
				 class="logo-img">

			<div class="logo-text">
				<h2>S.V.M</h2>
				<span>Admin Panel</span>
			</div>

		</div>

		<!-- Admin Dropdown - exactly like submenu-item -->
		<div class="admin-dropdown" tabindex="0">
			<a href="javascript:void(0)">Admin <i class="fa fa-chevron-down"></i></a>
			<div class="admin-dropdown-menu">
				<a asp-action="Create" asp-route-fixedGroupId="1" asp-controller="Users" asp-route-groupId="1">
					<i class="fa fa-user-plus"></i> Add Admin
				</a>
					
				<a asp-controller="Account" asp-action="Logout">
					<i class="fa fa-sign-out-alt"></i> Logout
				</a>
			</div>
		</div>
	</div>

	<div class="menu">
		<ul>

			<li>
				<a asp-action="AdminDashboard" asp-controller="Admin" target="mainFrame">
					<i class="fa fa-home"></i> Dashboard
				</a>
			</li>

			<!-- STUDENT MANAGEMENT -->

			<li>
				<a href="#">
					<i class="fa fa-user-graduate"></i>
					Student Management
				</a>

				<div class="submenu">

					<a asp-controller="Students"
					   asp-action="Create"
					   target="mainFrame">
						New Admission
					</a>

					<a asp-controller="Students"
					   asp-action="Index"
					   target="mainFrame">
						Student List
					</a>

					<a href="#">
						Promotion
					</a>

					<div class="submenu-item">

						<a href="#">
							Student Fees
						</a>

						<div class="submenu2">

							<a href="#">
								Pay Fees
							</a>

							<a href="#">
								Fees Reports
							</a>
						</div>

					</div>
					<div class="submenu-item">

						<a href="#">
							Student Attendance
						</a>

						<div class="submenu2">

							<a target="mainFrame" asp-action="Index" asp-controller="StudentAttendances">
								Daily report
							</a>

							<a target="mainFrame" asp-action="MonthlyReport" asp-controller="StudentAttendances">
								Monthly Report
							</a>
						</div>

					</div>

					

				</div>
			</li>

			<!-- STAFF -->
			<li>
				<a href="#"><i class="fa fa-chalkboard-teacher"></i> Staff</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Staffs" target="mainFrame">Staff</a>

					<a href="#">Salary</a>
				</div>
			</li>

			<!-- academic menu -->
			<li>
				<a href="#"><i class="fa fa-book"></i> Academic</a>
				<div class="submenu">
					<div class="submenu-item">
						@* <a> Classes & Sections</a> *@
						<a asp-action="Index" asp-controller="Classes" target="mainFrame"> Classes & Sections</a>
						@* <div class="submenu2">
							<a asp-action="Index" asp-controller="Classes" target="mainFrame"> Classes</a>
							<a asp-action="Index" asp-controller="Sections" target="mainFrame"> Division</a>
						</div> *@
					</div>
					<a target="mainFrame" asp-controller="Subjects" asp-action="Index">Subjects</a>
					<a target="mainFrame" asp-controller="TeacherSubjects" asp-action="Index">Subject Allocation</a>
					@* <a target="mainFrame" asp-controller="TeacherSubjects" asp-action="Index">Subject Assignment</a> *@
					<a target="mainFrame" asp-controller="FeesStructures" asp-action="Index">Fee Structure</a>

					<a href="#">Exams</a>
					<div class="submenu-item">
						<a href="#">Results</a>
						<div class="submenu2">
							<a href="#">Result Entry</a>
							<a href="#">Report Card</a>
						</div>
					</div>
					<a target="mainFrame" asp-controller="Timetables" asp-action="Index">Timetable</a>
				</div>
			</li>
			<!-- account menu -->
			<li>
				<a href="#"><i class="fa fa-wallet"></i> Accounts</a>
				<div class="submenu">
					<a href="#">Fees</a>
					<a target="mainFrame" asp-controller="Expenses" asp-action="Index">Daily Expenses</a>
					
					<a href="#">Salary</a>
				</div>
			</li>

			<!-- settings menu -->
			<li>
				<a href="#"><i class="fa fa-cog"></i> Settings</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Sessions" target="mainFrame">Session</a>
					<a asp-action="Index" asp-controller="Updates" target="mainFrame">Notice & Event</a>

				</div>
			</li>

		</ul>
	</div>

	<iframe id="mainFrame" name="mainFrame"></iframe>

</body>
<script src="~/js/AdminPanel.js"></script>
</html>