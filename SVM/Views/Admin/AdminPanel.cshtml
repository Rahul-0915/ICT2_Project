@model List<SVM.Models.Updates>

@using Microsoft.AspNetCore.Http

@{
	Layout = null;

	// Session Check
	if (Context.Session.GetString("UserId") == null)
	{
		Context.Response.Redirect("/Account/Login");
	}

	// Only Admin Allowed
	if (Context.Session.GetString("GroupId") != "1")
	{
		Context.Session.Clear();
		Context.Response.Redirect("/Account/Login");
	}

	// Prevent Back After Logout
	Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
	Context.Response.Headers["Pragma"] = "no-cache";
	Context.Response.Headers["Expires"] = "0";
}
<!DOCTYPE html>
<html>

<head>
	<title>S.V.M Admin Panel</title>
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="~/css/AdminSide_Css/AdminPanel.css" asp-append-version="true" />
</head>

<body>

	<!-- HEADER -->
	<div class="header">

		<div class="logo">

			<img src="/images/svmGuj_Logo.png"
				 alt="SVM Logo"
				 class="logo-img">

			<div class="logo-text">
				<h2>S.V.M</h2>
				<span>Admin Panel</span>
			</div>

		</div>

		<!-- Admin Dropdown - exactly like submenu-item -->
		<div class="admin-dropdown" tabindex="0">

			<a href="javascript:void(0)">
				Welcome, @Context.Session.GetString("Username")
				<i class="fa fa-chevron-down"></i>
			</a>
			<div class="admin-dropdown-menu">
				<a asp-action="Create" asp-route-fixedGroupId="1" target="mainFrame" asp-controller="Users" asp-route-groupId="1">
					<i class="fa fa-user-plus"></i> Add Admin
				</a>

				<a asp-controller="Account" asp-action="Logout">
					<i class="fa fa-sign-out-alt"></i> Logout
				</a>
			</div>
		</div>
	</div>

	<div class="menu">
		<ul>

			<li>
				<a asp-action="AdminDashboard" asp-controller="Admin" target="mainFrame">
					<i class="fa fa-home"></i> Dashboard
				</a>
			</li>

			<!-- ================= STUDENT MANAGEMENT ================= -->
			<li>
				<a href="#">
					<i class="fa fa-user-graduate"></i>
					Student Management

					<span class="menu-badge inq-count" style="display:none;">0</span>
				</a>
				<div class="submenu">
					<div class="submenu-item">
						<a href="#">
							Admission

							<span class="menu-badge inq-count" style="display:none;">0</span>
						</a>
						<div class="submenu2">
							<a asp-controller="Students" asp-action="Create" target="mainFrame">New Admission</a>
							<a asp-controller="AdmissionInquiries"
							   asp-action="Index"
							   target="mainFrame">

								Admission Inquiries

								<span class="menu-badge inq-count" style="display:none;">0</span>
							</a>
						</div>
					</div>
					<a asp-controller="Students" asp-action="Index" target="mainFrame">Student List</a>
					<a asp-controller="Students" asp-action="Promotion" target="mainFrame">Promotion</a>

					<div class="submenu-item">
						<a href="#">Student Attendance</a>
						<div class="submenu2">
							<a target="mainFrame" asp-action="Index" asp-controller="StudentAttendances">Daily Report</a>
							<a target="mainFrame" asp-action="MonthlyReport" asp-controller="StudentAttendances">Monthly Report</a>
						</div>
					</div>
				</div>
			</li>

			<!-- ================= STAFF ================= -->
			<li>
				<a href="#"><i class="fa fa-chalkboard-teacher"></i> Staff</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Staffs" target="mainFrame">Staff List</a>

				</div>
			</li>

			<!-- ================= ACADEMIC ================= -->
			<li>
				<a href="#"><i class="fa fa-book"></i> Academic</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Classes" target="mainFrame">Classes & Sections</a>
					<a target="mainFrame" asp-controller="Subjects" asp-action="Index">Subjects</a>
					<a target="mainFrame" asp-controller="TeacherSubjects" asp-action="Index">Subject Allocation</a>
					<a target="mainFrame" asp-controller="Timetables" asp-action="Index">Timetable</a>

				</div>
			</li>
			<li>
				<a href="#"><i class="fa fa-clipboard-list"></i> Exam Management</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Exams" target="mainFrame">
						Create Exam & Marks Entry
					</a>

					<a asp-action="Report" asp-controller="Exams" target="mainFrame">
						Result Report
					</a>
				</div>
			</li>
			<!-- ================= ACCOUNTS (Fees + Salary yahan ayega) ================= -->
			<!-- ================= ACCOUNTS (Fees + Salary yahan ayega) ================= -->
			<li>
				<a href="#"><i class="fa fa-wallet"></i> Accounts</a>
				<div class="submenu">
					<!-- Student Fees -->
					<div class="submenu-item">
						<a href="#">Student Fees</a>
						<div class="submenu2">
							<a target="mainFrame" asp-controller="Admin" asp-action="FeesPayment">Collect Fees & Report</a>
							<a target="mainFrame" asp-controller="FeeReports" asp-action="Index">
								Fee Collection Report
							</a>


						</div>
					</div>
					<!-- Fee Structure -->
					<a target="mainFrame" asp-controller="FeesStructures" asp-action="Index">Fee Structure</a>
					<!-- Staff Salary -->
					<div class="submenu-item">
						
						<div class="submenu2">
							<a href="#">Generate Salary</a>
							<a href="#">Salary Report</a>
						</div>
					</div>
					<!-- Expenses -->
					<a target="mainFrame" asp-controller="Expenses" asp-action="Index">Daily Expenses</a>
				</div>
			</li>

			<!-- ================= SETTINGS ================= -->
			<li>
				<a href="#"><i class="fa fa-cog"></i> Settings</a>
				<div class="submenu">
					<a asp-action="Index" asp-controller="Sessions" target="mainFrame">Session</a>
					<a asp-action="Index" asp-controller="Updates" target="mainFrame">Notice & Event</a>
				</div>
			</li>

		</ul>
	</div>
	<div id="pageLoader" style="display:none;">
		<i class="fa fa-spinner fa-spin"></i>
		Loading...
	</div>
	<iframe id="mainFrame" name="mainFrame"></iframe>

</body>
<script src="~/js/AdminPanel.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="~/js/AdminPanel.js"></script>
<script>
	let lastCount = -1;

	async function loadInquiryCount() {
		try {
			const res = await fetch('/AdmissionInquiries/GetUnseenInquiryCount');
			const count = await res.json();

			// 🚀 ONLY update DOM if value changed
			if (count !== lastCount) {
				lastCount = count;

				document.querySelectorAll(".inq-count").forEach(el => {
					if (count > 0) {
						el.style.display = "inline-flex";
						el.innerText = count;
					} else {
						el.style.display = "none";
					}
				});
			}

		} catch (e) {
			console.log("notification error", e);
		}
	}

	// initial load
	loadInquiryCount();

	// real-time polling
	setInterval(loadInquiryCount, 3000);

	$(document).ready(function () {

		$("a[target='mainFrame']").click(function () {
			$("#pageLoader").show();
		});

		$("#mainFrame").on("load", function () {
			$("#pageLoader").hide();
		});

	});
</script>
</html>