@model List<SVM.Models.Updates>

@using Microsoft.AspNetCore.Http

@{
	Layout = null;

	// Session Check
	if (Context.Session.GetString("UserId") == null)
	{
		Context.Response.Redirect("/Account/Login");
	}

	// Only Admin Allowed
	if (Context.Session.GetString("GroupId") != "1")
	{
		Context.Session.Clear();
		Context.Response.Redirect("/Account/Login");
	}

	// Prevent Back After Logout
	Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
	Context.Response.Headers["Pragma"] = "no-cache";
	Context.Response.Headers["Expires"] = "0";
}
<html>
<head>
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="~/css/AdminSide_Css/AdminPanel.css" asp-append-version="true" />
	<style>

	</style>
</head>

<div class="container">
	<div class="grid">
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "Students")'"
			 style="cursor:pointer;">
			<div class="iconBox c1"><i class="fa fa-user-graduate"></i></div>
			<h2>@ViewBag.TotalStudents</h2>
			totalStudents
		</div>
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "Staffs")'"
			 style="cursor:pointer;">
			<div class="iconBox c2"><i class="fa fa-chalkboard-teacher"></i></div>
			<h2>@ViewBag.TotalStaff</h2>
			Staff
		</div>
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("FeesPayment", "Admin")'"
			 style="cursor:pointer;">
			<div class="iconBox c3"><i class="fa fa-money-bill"></i></div>
			<h2>₹@Convert.ToDecimal(ViewBag.TotalFeesCollection).ToString("N0")</h2>
			Fees
		</div>
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "Expenses")'"
			 style="cursor:pointer;">
			<div class="iconBox c4"><i class="fa fa-wallet"></i></div>
			<h2>₹@Convert.ToDecimal(ViewBag.TotalExpense).ToString("N0")</h2>
			Expenses
		</div>
		@* 	<div class="panel">
			<div class="iconBox c5"><i class="fa fa-calendar-check"></i></div>
			<h2>92%</h2>
			Attendance
		</div> *@
		@* 	<div class="panel">
			<div class="iconBox c6"><i class="fa fa-file"></i></div>
			<h2>25</h2>
			Exams
		</div> *@
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "AdmissionInquiries")'"
			 style="cursor:pointer;">
			<div class="iconBox c8">
				<i class="fa fa-list"></i>
			</div>
			<h2>@ViewBag.TotalInquiries</h2>
			Total Inquiries
		</div>
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "AdmissionInquiries")'"
			 style="cursor:pointer;">
			<div class="iconBox c1">
				<i class="fa fa-bell"></i>
			</div>

			<h2 class="inq-count">0</h2>

			New Inquiries
		</div>
		<div class="panel" onclick="parent.frames['mainFrame'].location.href='@Url.Action("Index", "Classes")'"
			 style="cursor:pointer;">
			<div class="iconBox c7"><i class="fa fa-school"></i></div>
			<h2>@ViewBag.TotalClasses</h2>
			Classes
		</div>
		<div class="panel">
			<div class="iconBox c8"><i class="fa fa-clock"></i></div>
			<h2>@ViewBag.ActiveSessionName</h2>
			Session
		</div>
	</div>

	<div class="bottom">
		@* 	<div class="box">
			<h3>Recent Activity</h3>
			<p>New student added</p>
			<p>Fees submitted</p>
			<p>Expense added</p>
		</div> *@

		@* <div class="box">
			<h3>Upcoming Exams</h3>
			<p>Math – 10 April</p>
			<p>Science – 12 April</p>
		</div> *@

		<div class="Noticesbox">
			<h3>Notices & Events</h3>
			@if (Model != null && Model.Count > 0)
			{
				var activeItems = Model.Where(u => u.Status == 1).OrderByDescending(u => u.CreatedAt).ToList();
				if (activeItems.Count > 0)
				{
					// Take only the latest 3
					var latestItems = activeItems.Take(3).ToList();
					<ul class="notice-list">
						@foreach (var item in latestItems)
						{
							<li>
								<a asp-controller="Updates" asp-action="Details" asp-route-id="@item.Id">
									@item.Title
								</a>
							</li>
						}
					</ul>
					if (activeItems.Count > 3)
					{
						<a asp-controller="Updates" asp-action="Index" class="show-more">
							Show more...
						</a>
					}
				}
				else
				{
					<p>No active notices or events.</p>
				}
			}
			else
			{
				<p>No notices or events available.</p>
			}
		</div>

	</div>
</div>
</html>
<script>
	let lastCount = -1;

	async function loadInquiryCount() {
		try {
			const res = await fetch('/AdmissionInquiries/GetUnseenInquiryCount');
			const count = await res.json();

			//  ONLY update DOM if value changed
			if (count !== lastCount) {
				lastCount = count;

				document.querySelectorAll(".inq-count").forEach(el => {
					if (count > 0) {
						el.style.display = "inline-flex";
						el.innerText = count;
					} else {
						el.style.display = "none";
					}
				});
			}

		} catch (e) {
			console.log("notification error", e);
		}
	}

	// initial load
	loadInquiryCount();

	// real-time polling
	setInterval(loadInquiryCount, 3000);
</script>