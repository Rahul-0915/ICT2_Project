@model SVM.Models.Session

@{
    ViewData["Title"] = "Delete";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />


<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Session</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SessionName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SessionName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StartDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StartDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndDate)
        </dd>
        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @{
                var today = DateOnly.FromDateTime(DateTime.Today);
                string statusText;
                string statusClass;

                if (today >= Model.StartDate && today <= Model.EndDate)
                {
                    statusText = "Active";
                    statusClass = "status-active";
                }
                else if (today < Model.StartDate)
                {
                    statusText = "Upcoming";
                    statusClass = "status-upcoming";
                }
                else
                {
                    statusText = "Expired";
                    statusClass = "status-expired";
                }
            }
            <span class="@statusClass">@statusText</span>
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="SessionId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>