@model IEnumerable<SVM.Models.Session>

@{
    ViewData["Title"] = "Index";
}

<link rel="stylesheet" href="~/css/AdminSide_Css/SessionDisplay.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/AdminSide_Css/SearchBar.css" asp-append-version="true" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="top-bar">

    <div class="left-side">

        <input type="text"
               id="searchInput"
               placeholder="Search session..."
               class="search-box" />

        <!-- STATUS FILTER -->

        <select id="statusFilter" class="search-box">

            <option value="">All Status</option>

            <option value="active">Active</option>

            <option value="upcoming">Upcoming</option>

            <option value="expired">Expired</option>

        </select>
        <button type="button"
                class="search-btn"
                onclick="filterTable()">

            <i class="fa-solid fa-magnifying-glass"></i>
            Search


        </button>
        <button type="button"
                class="reset-btn"
                onclick="resetFilter()">

            Reset

        </button>
    </div>
        <a asp-action="Create"
           class="add-btn">
            <i class="fa-solid fa-plus"></i>
        </a>

       
</div>



<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SessionName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                Status
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            // Calculate status based on dates
            var today = DateOnly.FromDateTime(DateTime.Today);
            var statusText = "";
            var statusClass = "";

            if (today >= item.StartDate && today <= item.EndDate)
            {
                statusText = "Active";
                statusClass = "status-active";
            }
            else if (today < item.StartDate)
            {
                statusText = "Upcoming";
                statusClass = "status-upcoming";
            }
            else
            {
                statusText = "Expired";
                statusClass = "status-expired";
            }

            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.SessionName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.StartDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EndDate)
                </td>
                <td>
                    <span class="@statusClass">@statusText</span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.SessionId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.SessionId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.SessionId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
    
</table>
<p id="noDataMessage"
   style="display:none;
        text-align:center;
          color:black;
          font-weight:900;
          margin-top:15px;">

    Data not found

</p>
<script src="/js/AdminSide_Js/Session.js"></script>