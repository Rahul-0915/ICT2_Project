@model SVM.Models.Session

@{
    ViewData["Title"] = "Edit Session";
}

<!DOCTYPE html>
<html>
<head>

    <title>Edit Session</title>

    <link rel="stylesheet"
          href="~/css/AdminSide_Css/Forms.css"
          asp-append-version="true" />

</head>

<body>

    <div class="session-page">

        <h1 class="page-title">Session Management</h1>

        <div class="session-card">

            <h2 class="card-title">Edit Session</h2>

            <form asp-action="Edit" class="session-form">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger">
                </div>

                <input type="hidden" asp-for="SessionId" />

                <div class="form-grid">

                    <!-- Session Name -->

                    <div class="form-group">

                        <input asp-for="SessionName"
                               class="form-control"
                               placeholder="Session Name (2024-25)" />

                        <span asp-validation-for="SessionName"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- Start Date -->

                    <div class="form-group">

                        <input asp-for="StartDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="StartDate"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- End Date -->

                    <div class="form-group">

                        <input asp-for="EndDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="EndDate"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <div style="display:flex; gap:15px; flex-wrap:wrap;">

                    <button type="submit" class="create-btn">
                        Save Changes
                    </button>


                    <button asp-action="Index" class="Back-btn">
                        Back to List
                    </button>

                </div>

            </form>

        </div>

    </div>

</body>
</html>