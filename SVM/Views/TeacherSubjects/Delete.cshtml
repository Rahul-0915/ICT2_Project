@model SVM.Models.TeacherSubject

@{
	ViewData["Title"] = "Delete";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
	<h4>TeacherSubject</h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Staff)
		</dt>
		<dd class="col-sm-10">
			@if (Model.Staff != null)
			{
				@($"{Model.Staff.FirstName} {Model.Staff.LastName}")
			}
			else
			{
				<span>N/A</span>
			}
		</dd>

		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Subject)
		</dt>
		<dd class="col-sm-10">
			@if (Model.Subject != null)
			{
				@Model.Subject.SubjectName
			}
			else
			{
				<span>N/A</span>
			}
		</dd>

		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Class)
		</dt>
		<dd class="col-sm-10">
			@if (Model.Class != null)
			{
				@Model.Class.ClassName
			}
			else
			{
				<span>N/A</span>
			}
		</dd>

		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Session)
		</dt>
		<dd class="col-sm-10">
			@if (Model.Session != null)
			{
				@Model.Session.SessionName
			}
			else
			{
				<span>N/A</span>
			}
		</dd>
	</dl>

	<form asp-action="Delete">
		<input type="hidden" asp-for="Id" />
		<input type="submit" value="Delete" class="btn btn-danger" /> |
		<a asp-action="Index">Back to List</a>
	</form>
</div>