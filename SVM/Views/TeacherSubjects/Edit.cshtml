@model SVM.Models.TeacherSubject

@{
    ViewData["Title"] = "Edit Subject Assignment";
}

<link rel="stylesheet" href="~/css/AdminSide_Css/SubjectAllocationForm.css" asp-append-version="true" />

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header">
            <i class="fas fa-edit"></i> Update Subject Allocation
        </div>

        <!-- BODY -->
        <div class="card-body">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <!-- TEACHER -->
                    <div class="col-md-6">
                        <label asp-for="StaffId" class="form-label">Teacher</label>
                        <select asp-for="StaffId" class="form-select" asp-items="ViewBag.StaffId">
                            <option value="">-- Select Teacher --</option>
                        </select>
                        <span asp-validation-for="StaffId" class="text-danger"></span>
                    </div>

                    <!-- SUBJECT -->
                    <div class="col-md-6">
                        <label asp-for="SubjectId" class="form-label">Subject</label>
                        <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.SubjectId">
                            <option value="">-- Select Subject --</option>
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>

                    <!-- CLASS -->
                    <div class="col-md-6">
                        <label asp-for="ClassId" class="form-label">Class</label>
                        <select asp-for="ClassId" class="form-select" asp-items="ViewBag.ClassId">
                            <option value="">-- Select Class --</option>
                        </select>
                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>

                    <!-- SESSION -->
                    <div class="col-md-6">
                        <label asp-for="SessionId" class="form-label">Session</label>
                        <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId">
                            <option value="">-- Select Session --</option>
                        </select>
                        <span asp-validation-for="SessionId" class="text-danger"></span>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="form-group mt-4">

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>

                </div>

            </form>

        </div>
    </div>

</div>