@model SVM.Models.TeacherSubject

@{
    ViewData["Title"] = "Edit Subject Assignment";
}

<link rel="stylesheet" href="~/css/AdminSide_Css/SubjectAllocationForm.css" asp-append-version="true" />

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header">
            <i class="fas fa-edit"></i> Update Subject Allocation
        </div>

        <!-- BODY -->
        <div class="card-body">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <!-- TEACHER -->
                    <div class="col-md-6">
                        <label asp-for="StaffId" class="form-label">Teacher</label>
                        <select asp-for="StaffId" class="form-select" asp-items="ViewBag.StaffId">
                            <option value="">-- Select Teacher --</option>
                        </select>
                        <span asp-validation-for="StaffId" class="text-danger"></span>
                    </div>

                    <!-- SESSION -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="SessionId" class="form-label fw-semibold">Session</label>

                            <select asp-for="SessionId"
                                    id="SessionId"
                                    class="form-select"
                                    asp-items="ViewBag.SessionId">

                                <option value="">-- Select Session --</option>

                            </select>

                            <span asp-validation-for="SessionId"
                                  class="text-danger"></span>
                        </div>
                    </div>

                    <!-- MEDIUM -->
                    <div class="col-md-6">
                        <div class="form-group">

                            <label class="form-label fw-semibold">Medium</label>

                            <select id="Medium" class="form-select">

                                <option value="">-- Select Medium --</option>

                                @if (ViewBag.SelectedMedium == "Gujarati")
                                {
                                    <option value="Gujarati" selected>Gujarati</option>
                                    <option value="English">English</option>
                                }
                                else
                                {
                                    <option value="Gujarati">Gujarati</option>
                                    <option value="English" selected>English</option>
                                }

                            </select>

                        </div>
                    </div>

                    <!-- CLASS -->
                    <div class="col-md-6">
                        <div class="form-group">

                            <label asp-for="ClassId"
                                   class="form-label fw-semibold">Class</label>

                            <select asp-for="ClassId"
                                    id="ClassId"
                                    class="form-select"
                                    asp-items="ViewBag.ClassId">

                                <option value="">-- Select Class --</option>

                            </select>

                            <span asp-validation-for="ClassId"
                                  class="text-danger"></span>

                        </div>
                    </div>

                    <!-- SUBJECT -->
                    <div class="col-md-6">
                        <div class="form-group">

                            <label asp-for="SubjectId"
                                   class="form-label fw-semibold">Subject</label>

                            <select asp-for="SubjectId"
                                    id="SubjectId"
                                    class="form-select"
                                    asp-items="ViewBag.SubjectId">

                                <option value="">-- Select Subject --</option>

                            </select>

                            <span asp-validation-for="SubjectId"
                                  class="text-danger"></span>

                        </div>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="form-group mt-4">

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>

                </div>

            </form>

        </div>
    </div>

</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).ready(function () {

        // MEDIUM + SESSION => CLASS

        $('#Medium, #SessionId').change(function () {

            let medium =
                $('#Medium').val();

            let sessionId =
                $('#SessionId').val();

            if (!medium || !sessionId)
                return;

            $('#ClassId')
                .html('<option>Loading...</option>');

            $.ajax({

                url: '/TeacherSubjects/GetClassesBySessionMedium',

                type: 'GET',

                data: {
                    sessionId: sessionId,
                    medium: medium
                },

                success: function (data) {

                    $('#ClassId').empty();

                    $('#ClassId').append(
                        '<option value="">-- Select Class --</option>'
                    );

                    $.each(data, function (i, item) {

                        $('#ClassId').append(
                            `<option value="${item.value}">
                                    ${item.text}
                                </option>`
                        );

                    });

                }

            });

        });

        // CLASS => SUBJECT

        $('#ClassId').change(function () {

            let classId =
                $(this).val();

            if (!classId)
                return;

            $('#SubjectId')
                .html('<option>Loading...</option>');

            $.ajax({

                url: '/TeacherSubjects/GetSubjectsByClass',

                type: 'GET',

                data: {
                    classId: classId
                },

                success: function (data) {

                    $('#SubjectId').empty();

                    $('#SubjectId').append(
                        '<option value="">-- Select Subject --</option>'
                    );

                    $.each(data, function (i, item) {

                        $('#SubjectId').append(
                            `<option value="${item.value}">
                                    ${item.text}
                                </option>`
                        );

                    });

                }

            });

        });

    });

</script>