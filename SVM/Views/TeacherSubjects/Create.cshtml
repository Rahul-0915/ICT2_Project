@model SVM.Models.TeacherSubject

@{
    ViewData["Title"] = "Assign Subject to Teacher";
}
<link rel="stylesheet" href="~/css/AdminSide_Css/SubjectAllocationForm.css" asp-append-version="true" />

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h3 class="mb-0"><i class="fas fa-chalkboard-teacher"></i> Subject Allocation</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <!-- Staff Dropdown -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="StaffId" class="form-label fw-semibold">Teacher</label>
                            <select asp-for="StaffId" class="form-select" asp-items="ViewBag.StaffId">
                                <option value="">-- Select Teacher --</option>
                            </select>
                            <span asp-validation-for="StaffId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Subject Dropdown -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="SubjectId" class="form-label fw-semibold">Subject</label>
                            <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.SubjectId">
                                <option value="">-- Select Subject --</option>
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Class Dropdown -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ClassId" class="form-label fw-semibold">Class</label>
                            <select asp-for="ClassId" class="form-select" asp-items="ViewBag.ClassId">
                                <option value="">-- Select Class --</option>
                            </select>
                            <span asp-validation-for="ClassId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Session Dropdown -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="SessionId" class="form-label fw-semibold">Session</label>
                            <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId">
                                <option value="">-- Select Session --</option>
                            </select>
                            <span asp-validation-for="SessionId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="form-group mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save"></i> Assign
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

