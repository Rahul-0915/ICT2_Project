@model IEnumerable<SVM.Models.TeacherSubject>

@{
    ViewData["Title"] = "Teacher Subject Assignments";

    var groupedTeachers = Model
        .GroupBy(x => new
        {
            x.StaffId,
            TeacherName = x.Staff != null
                ? x.Staff.FirstName + " " + x.Staff.LastName
                : "N/A"
        });
}

<link rel="stylesheet" href="~/css/AdminSide_Css/TeacherSubject.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/AdminSide_Css/SearchBar.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="assignment-page">

    <!-- TOP BAR -->
    <div class="top-bar">
        <form method="get" asp-action="Index" class="left-side" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">

            <!-- Search Teacher (optional client-side filter) -->
            <input type="text" id="searchInput" placeholder="Search teacher..." class="search-box" />

            <!-- Session Dropdown (server‑side) -->
            <select id="sessionFilter" name="sessionId" class="search-box" asp-items="ViewBag.SessionId"></select>

            <select id="mediumFilter" name="medium" class="search-box">
                <option value="">All Medium</option>
                @foreach (string m in ViewBag.Mediums)
                {
                    <option value="@m" selected="@(ViewBag.SelectedMedium == m)">@m</option>
                }
            </select>

            <!-- Class Dropdown (server‑side) -->
            <select id="classFilter" name="classId" class="search-box" asp-items="ViewBag.ClassId">
                <option value="">All Classes</option>
            </select>

            <!-- Submit Button (server‑side filter) -->
            <button type="submit" class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i> Search
            </button>

            <!-- Reset Button (back to Index without filters) -->
            
            <button type="button"
                    class="reset-btn"
                    onclick="resetFilter()">

                Reset

            </button>
        </form>

        <a asp-action="Create" class="add-btn"><i class="fa-solid fa-plus"></i></a>
    </div>

    @if (!Model.Any() && !(bool)(ViewBag.HasFilter ?? false))
    {
        <h2 class="page-info">
            Search teacher or select class to view Subject Allocation
        </h2>
    }

    <div class="teacher-container">
        @foreach (var teacher in groupedTeachers)
        {
            <div class="teacher-card">
                <div class="teacher-header">
                    <div class="teacher-left">
                        <div class="teacher-icon">
                            @if (!string.IsNullOrEmpty(teacher.FirstOrDefault()?.Staff?.StafPhoto))
                            {
                                <img src="@teacher.FirstOrDefault()?.Staff?.StafPhoto" alt="Teacher Photo" />
                            }
                            else
                            {
                                <i class="fa-solid fa-user"></i>
                            }
                        </div>
                        <div>
                            <h2 class="teacher-name">@teacher.Key.TeacherName</h2>
                            <p class="teacher-count">@teacher.Count() Subject Assigned</p>
                        </div>
                    </div>
                </div>

                <div class="subject-table-wrapper">
                    <table class="subject-table">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Class & Medium</th>
                                <th>Session</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in teacher)
                            {
                                <tr>
                                    <td>@(item.Subject?.SubjectName ?? "N/A")</td>
                                    <td class="class-cell">
                                        <div class="class-medium-wrap">
                                            <span class="class-badge">@(item.Class?.ClassName ?? "N/A")</span>
                                            <span class="medium-badge">@(item.Class?.Medium ?? "N/A")</span>
                                        </div>
                                    </td>
                                    <td>@(item.Session?.SessionName ?? "N/A")</td>
                                    <td>
                                        <div class="action-group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn edit-btn"><i class="fa-solid fa-pen"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn delete-btn"><i class="fa-solid fa-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any() && (ViewBag.HasFilter != null && (bool)ViewBag.HasFilter))
    {
        <div id="noDataMessage" class="no-data" style="display: block !important; text-align: center; padding: 20px; margin: 20px; background: #f8f9fa; border: 1px solid #ddd; border-radius: 5px; color: red; font-weight: bold;">
            <i class="fa-solid fa-circle-exclamation"></i>
            No Subject Allocation Found
        </div>
    }

</div>

<script>
    //  CLIENT-SIDE FILTER FOR TEACHER NAME ONLY 
    const searchInput = document.getElementById('searchInput');
    const teacherCards = document.querySelectorAll('.teacher-card');

    function filterByTeacherName() {
        const term = searchInput.value.toLowerCase().trim();
        teacherCards.forEach(card => {
            const teacherNameElem = card.querySelector('.teacher-name');
            if (teacherNameElem) {
                const name = teacherNameElem.innerText.toLowerCase();
                card.style.display = (term === '' || name.includes(term)) ? 'block' : 'none';
            }
        });
    }

    searchInput.addEventListener('keyup', filterByTeacherName);
    filterByTeacherName();

    //  CASCADE: SESSION + MEDIUM => CLASS (AJAX) 
    async function loadClasses() {
        const sessionId = document.getElementById('sessionFilter').value;
        const medium = document.getElementById('mediumFilter').value;
        const classDropdown = document.getElementById('classFilter');

        classDropdown.innerHTML = '<option value="">Loading...</option>';

        try {
            const response = await fetch(`/TeacherSubjects/GetClassesBySessionMedium?sessionId=${sessionId}&medium=${medium}`);
            if (!response.ok) throw new Error();
            const data = await response.json();
            classDropdown.innerHTML = '<option value="">All Classes</option>';
            data.forEach(item => {
                classDropdown.innerHTML += `<option value="${item.value}">${item.text}</option>`;
            });
        } catch (error) {
            classDropdown.innerHTML = '<option value="">All Classes</option>';
        }
    }

    document.getElementById('sessionFilter').addEventListener('change', loadClasses);
    document.getElementById('mediumFilter').addEventListener('change', loadClasses);
</script>   