@model IEnumerable<SVM.Models.TeacherSubject>

@{
    ViewData["Title"] = "Teacher Subject Assignments";

    var groupedTeachers = Model
        .GroupBy(x => new
        {
            x.StaffId,
            TeacherName = x.Staff != null
                ? x.Staff.FirstName + " " + x.Staff.LastName
                : "N/A"
        });
}

<link rel="stylesheet"
      href="~/css/AdminSide_Css/TeacherSubject.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="~/css/AdminSide_Css/SearchBar.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="assignment-page">

    <!-- TOP BAR -->

    <div class="top-bar">

        <div class="left-side">

            <!-- SEARCH -->

            <input type="text"
                   id="searchInput"
                   placeholder="Search teacher..."
                   class="search-box" />

            <!-- SESSION -->

            <select id="sessionFilter"
                    class="search-box">

                @foreach (var s in ViewBag.SessionId as SelectList)
                {
                    <option value="@s.Value"
                            selected="@(s.Selected ? "selected" : null)">
                        @s.Text
                    </option>
                }

            </select>

            <!-- MEDIUM -->

            <select id="mediumFilter"
                    class="search-box">

                <option value="">All Medium</option>

                @foreach (string m in ViewBag.Mediums)
                {
                    if (ViewBag.SelectedMedium == m)
                    {
                        <option selected value="@m">@m</option>
                    }
                    else
                    {
                        <option value="@m">@m</option>
                    }
                }

            </select>

            <!-- CLASS -->

            <select id="classFilter"
                    class="search-box">

                <option value="">All Classes</option>

                @foreach (var c in ViewBag.ClassId as SelectList)
                {
                    <option value="@c.Value"
                            selected="@(c.Selected ? "selected" : null)">
                        @c.Text
                    </option>
                }

            </select>

            <!-- SEARCH -->

            <button type="button"
                    class="search-btn"
                    onclick="applyFilter()">

                <i class="fa-solid fa-magnifying-glass"></i>
                Search

            </button>
            <button type="button"
                    class="reset-btn"
                    onclick="resetFilter()">

                Reset

            </button>

        </div>
        <!-- ADD -->

        <a asp-action="Create"
           class="add-btn">

            <i class="fa-solid fa-plus"></i>

        </a>

    </div>



    <!-- INFO -->

    <h2 id="page-info" class="page-info">

        Search teacher or select class to view Subject Allocation

    </h2>

    <!-- CONTAINER -->

    <div class="teacher-container">

        @foreach (var teacher in groupedTeachers)
        {
            <div class="teacher-card">

                <!-- HEADER -->

                <div class="teacher-header">

                    <div class="teacher-left">

                        <div class="teacher-icon">

                            @if (!string.IsNullOrEmpty(
                           teacher.FirstOrDefault()?.Staff?.StafPhoto))
                            {
                                <img src="@teacher.FirstOrDefault()?.Staff?.StafPhoto"
                                     alt="Teacher Photo" />
                            }
                            else
                            {
                                <i class="fa-solid fa-user"></i>
                            }

                        </div>

                        <div>

                            <h2 class="teacher-name">

                                @teacher.Key.TeacherName

                            </h2>

                            <p class="teacher-count">

                                @teacher.Count() Subject Assigned

                            </p>

                        </div>

                    </div>

                </div>

                <!-- SUBJECT TABLE -->

                <div class="subject-table-wrapper">

                    <table class="subject-table">

                        <thead>

                            <tr>
                                <th>Subject</th>
                                <th>Class & Medium </th>
                                <th>Session</th>
                                <th>Action</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in teacher)
                            {
                                <tr>

                                    <td>

                                        @(item.Subject?.SubjectName ?? "N/A")

                                    </td>

                                    <td class="class-cell">

                                        <div class="class-medium-wrap">

                                            <span class="class-badge">

                                                @(item.Class?.ClassName ?? "N/A")

                                            </span>

                                            <span class="medium-badge">

                                                @(item.Class?.Medium ?? "N/A")

                                            </span>

                                        </div>

                                    </td>

                                    <td>

                                        @(item.Session?.SessionName ?? "N/A")

                                    </td>

                                    <td>

                                        <div class="action-group">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="action-btn edit-btn">

                                                <i class="fa-solid fa-pen"></i>

                                            </a>

                                            @* <a asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="action-btn details-btn">

                                                <i class="fa-solid fa-eye"></i>

                                            </a> *@

                                            <a asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="action-btn delete-btn">

                                                <i class="fa-solid fa-trash"></i>

                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>
        }

    </div>

    <!-- NO DATA -->

    <div id="noDataMessage"
         class="no-data">

        No Subject Allocation Found

    </div>

</div>



<script>

    // DEFAULT HIDE
    document.querySelectorAll(".teacher-card")
        .forEach(card => {
            card.style.display = "none";
        });

    // ================= SEARCH FILTER =================

    function applyFilter() {

        let search =
            document.getElementById("searchInput")
                .value.toLowerCase().trim();

        let selectedClass =
            document.getElementById("classFilter")
                .options[
                document.getElementById("classFilter").selectedIndex
            ].text.toLowerCase();

        let selectedSession =
            document.getElementById("sessionFilter")
                .options[
                document.getElementById("sessionFilter").selectedIndex
            ].text.toLowerCase();

        let selectedMedium =
            document.getElementById("mediumFilter")
                .value.toLowerCase();

        let cards =
            document.querySelectorAll(".teacher-card");

        let visible = 0;

        cards.forEach(card => {

            let teacherName =
                card.querySelector(".teacher-name")
                    .innerText.toLowerCase();

            let rows =
                card.querySelectorAll("tbody tr");

            let showCard = false;

            rows.forEach(row => {

                let className =
                    row.querySelector(".class-badge")
                        ?.innerText.toLowerCase() || "";

                let mediumName =
                    row.querySelector(".medium-badge")
                        ?.innerText.toLowerCase() || "";

                let sessionName =
                    row.cells[2].innerText.toLowerCase();

                let teacherMatch =
                    search === "" ||
                    teacherName.includes(search);

                let classMatch =
                    selectedClass === "all classes" ||
                    selectedClass === "" ||
                    className.includes(selectedClass);

                let mediumMatch =
                    selectedMedium === "" ||
                    mediumName.includes(selectedMedium);

                let sessionMatch =
                    selectedSession === "" ||
                    sessionName.includes(selectedSession);

                if (
                    teacherMatch &&
                    classMatch &&
                    mediumMatch &&
                    sessionMatch
                ) {
                    showCard = true;
                }

            });

            if (showCard) {

                card.style.display = "block";
                visible++;

                document.getElementById("page-info")
                    .style.display = "none";
            }
            else {

                card.style.display = "none";
            }

        });

        // NO DATA MESSAGE

        document.getElementById("noDataMessage")
            .style.display =
            visible === 0 ? "block" : "none";

        document.getElementById("noDataMessage")
            .style.color = "red";
    }

    // ================= RESET =================

    function resetFilter() {

        document.getElementById("page-info")
            .style.display = "block";

        document.getElementById("searchInput").value = "";

        document.getElementById("mediumFilter").value = "";

        document.getElementById("classFilter").value = "";

        document.querySelectorAll(".teacher-card")
            .forEach(card => {
                card.style.display = "none";
            });

        document.getElementById("noDataMessage")
            .style.display = "none";
    }

    // ================= SESSION + MEDIUM => CLASS =================

    async function loadClasses() {

        let sessionId =
            document.getElementById("sessionFilter").value;

        let medium =
            document.getElementById("mediumFilter").value;

        let classDropdown =
            document.getElementById("classFilter");

        classDropdown.innerHTML =
            '<option value="">Loading...</option>';

        let response =
            await fetch(`/TeacherSubjects/GetClassesBySessionMedium?sessionId=${sessionId}&medium=${medium}`);

        let data = await response.json();

        classDropdown.innerHTML =
            '<option value="">All Classes</option>';

        data.forEach(item => {

            classDropdown.innerHTML +=
                `<option value="${item.value}">
                        ${item.text}
                    </option>`;
        });
    }

    document.getElementById("sessionFilter")
        .addEventListener("change", loadClasses);

    document.getElementById("mediumFilter")
        .addEventListener("change", loadClasses);

</script>