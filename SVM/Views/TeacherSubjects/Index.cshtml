@model IEnumerable<SVM.Models.TeacherSubject>

@{
	ViewData["Title"] = "Subject Assignments";
}
<link rel="stylesheet" href="~/css/List.css" asp-append-version="true" />

<h1>Subject Assignments</h1>

<p>
	<a asp-action="Create" class="btn btn-primary">Create New Assignment</a>
</p>

<table class="table table-striped table-hover">
	<thead>
		<tr>
			<th>Teacher</th>
			<th>Subject</th>
			<th>Class</th>
			<th>Session</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@if (item.Staff != null)
					{
						@($"{item.Staff.FirstName} {item.Staff.LastName}")
					}
					else
					{
						<span class="text-muted">N/A</span>
					}
				</td>
				<td>
					@if (item.Subject != null)
					{
						@item.Subject.SubjectName
					}
					else
					{
						<span class="text-muted">N/A</span>
					}
				</td>
				<td>
					@if (item.Class != null)
					{
						@item.Class.ClassName
					}
					else
					{
						<span class="text-muted">N/A</span>
					}
				</td>
				<td>
					@if (item.Session != null)
					{
						@item.Session.SessionName
					}
					else
					{
						<span class="text-muted">N/A</span>
					}
				</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
					<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
					<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>