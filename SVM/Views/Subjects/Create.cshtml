@model SVM.Models.Subject

@{
    ViewData["Title"] = "Create Subject";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/AdminSide_Css/Forms.css" asp-append-version="true" />
    <title>Create Subject</title>
</head>

<body>

    <div class="session-page">

        <div class="session-card">

            <h3 class="card-title">Add Subject</h3>

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-grid">

                    <!-- MEDIUM -->
                    <div class="form-group">
                        <label>Medium</label>

                        <select id="Medium" class="form-control">
                            <option value="">-- Select Medium --</option>
                            <option value="Gujarati">Gujarati</option>
                            <option value="English">English</option>
                        </select>
                    </div>

                    <!-- CLASS -->
                    <div class="form-group">
                        <label>Select Class</label>

                        <select asp-for="ClassId"
                                id="ClassId"
                                class="form-control">

                            <option value="">-- Select Class --</option>

                        </select>

                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>

                    <!-- SUBJECT NAME -->
                    <div class="form-group">
                        <label>Subject Name</label>

                        <input asp-for="SubjectName"
                               class="form-control"
                               placeholder="e.g. Mathematics, Science, English" />

                        <span asp-validation-for="SubjectName" class="text-danger"></span>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div style="display:flex; gap:15px; flex-wrap:wrap;">

                    <input type="submit" value="Create" class="create-btn" />

                    <a asp-action="Index">
                        <button type="button" class="Back-btn">← Back to List</button>
                    </a>

                </div>

            </form>

        </div>

    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#Medium').change(function () {

                var medium = $(this).val();
                var ddl = $('#ClassId');

                if (medium === '') {
                    ddl.html('<option value="">-- Select Class --</option>');
                    return;
                }

                ddl.html('<option>Loading...</option>');

                $.ajax({
                    url: '/Subjects/GetClassesByMedium',
                    type: 'GET',
                    data: { medium: medium },

                    success: function (data) {

                        ddl.empty();
                        ddl.append('<option value="">-- Select Class --</option>');

                        $.each(data, function (i, item) {
                            ddl.append('<option value="' + item.value + '">' + item.text + '</option>');
                        });

                    },

                    error: function () {
                        ddl.html('<option>Error loading classes</option>');
                    }
                });

            });

        });
    </script>

</body>
</html>