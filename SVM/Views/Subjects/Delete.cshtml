@model SVM.Models.Subject

@{
    ViewData["Title"] = "Delete";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />

<!DOCTYPE html>
<html>
<head>
    <title>Delete Subject</title>
</head>
<body>
    <h1>Delete</h1>

    <h3>Are you sure you want to delete this?</h3>
    <div>
        <h4>Subject</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.SubjectName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SubjectName)
            </dd>
            <dt class="col-sm-2">
                Class
            </dt>
            <dd class="col-sm-10">
                @if (Model.Class != null)
                {
                    @($"{Model.Class.ClassName} - {Model.Class.Medium}")
                }
                else
                {
                    <span class="text-muted">N/A</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="SubjectId" />
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            <a asp-action="Index">Back to List</a>
        </form>
    </div>
</body>
</html>