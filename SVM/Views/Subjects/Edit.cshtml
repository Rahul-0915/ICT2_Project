@model SVM.Models.Subject

@{
    ViewData["Title"] = "Edit Subject";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/AdminSide_Css/Forms.css" asp-append-version="true" />
    <title>Edit Subject</title>
</head>

<body>

    <div class="session-page">

        <div class="session-card">

            <h3 class="card-title">Edit Subject</h3>

            <form asp-action="Edit">

                <input type="hidden" asp-for="SubjectId" />

                <div class="form-grid">

                    <!-- MEDIUM -->
                    <div class="form-group">
                        <label>Medium</label>
                        <select id="Medium" class="form-control">
                            <option value="">-- Select Medium --</option>
                            <option value="Gujarati">Gujarati</option>
                            <option value="English">English</option>
                        </select>
                    </div>

                    <!-- CLASS -->
                    <div class="form-group">
                        <label>Select Class</label>
                        <select asp-for="ClassId" id="ClassId" class="form-control">
                            <option value="">-- Select Class --</option>
                        </select>
                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>

                    <!-- SUBJECT NAME -->
                    <div class="form-group">
                        <label>Subject Name</label>
                        <input asp-for="SubjectName" class="form-control" />
                        <span asp-validation-for="SubjectName" class="text-danger"></span>
                    </div>

                </div>

                <div style="display:flex; gap:15px; flex-wrap:wrap;">

                    <input type="submit" value="Save" class="create-btn" />

                    <a asp-action="Index">
                        <button type="button" class="Back-btn">← Back to List</button>
                    </a>

                </div>

            </form>

        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

            var currentMedium = '@ViewBag.CurrentMedium';
            var currentClassId = '@ViewBag.CurrentClassId';

            if (currentMedium) {
                $('#Medium').val(currentMedium);
                loadClasses(currentMedium, currentClassId);
            }

            $('#Medium').change(function () {
                var medium = $(this).val();
                loadClasses(medium, null);
            });

            function loadClasses(medium, selectedId) {

                if (!medium) {
                    $('#ClassId').html('<option>-- Select Class --</option>');
                    return;
                }

                $.ajax({
                    url: '/Subjects/GetClassesByMedium',
                    type: 'GET',
                    data: { medium: medium },
                    success: function (data) {

                        $('#ClassId').empty();
                        $('#ClassId').append('<option value="">-- Select Class --</option>');

                        $.each(data, function (i, item) {

                            var selected = item.value == selectedId ? "selected" : "";

                            $('#ClassId').append(
                                `<option value="${item.value}" ${selected}>${item.text}</option>`
                            );

                        });

                    }
                });

            }

        });
    </script>

</body>
</html>