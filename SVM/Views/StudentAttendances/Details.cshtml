@model StudentAttendance

@{
	ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
	<h4>StudentAttendance</h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.AttendanceDate)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.AttendanceDate)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Status)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Status)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Class)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Class.ClassName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Section)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Section.SectionName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Session)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Session.SessionName)
		</dd>
		<dt class="col-sm-2">
			@Html.DisplayNameFor(model => model.Student)
		</dt>
		<dd class="col-sm-10">
			@Html.DisplayFor(model => model.Student.Address)
		</dd>
	</dl>
</div>
<div>
	<a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
	<a asp-action="Index"
	   asp-route-sessionId="@Model.SessionId"
	   asp-route-classId="@Model.ClassId"
	   asp-route-sectionId="@Model.SectionId"
	   asp-route-date="@Model.AttendanceDate.ToString("yyyy-MM-dd")"
	   asp-route-medium="@Model.Class?.Medium">
		Back to List
	</a>
</div>
