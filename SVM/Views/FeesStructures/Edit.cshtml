@model SVM.Models.FeeStructure

@{
	ViewData["Title"] = "Edit Fee Structure";
}

<link rel="stylesheet"
	  href="/css/AdminSide_Css/Fees_Structure_CreateForm.css"
	  asp-append-version="true" />

<div class="fee-page">

	<div class="fee-card">

		<!-- LEFT PANEL -->

		<div class="left-panel">

			<div class="school-title">
				S.V.M
			</div>

			<div class="school-sub">
				Fee Structures
			</div>

			<div class="fee-preview">

				<div class="preview-title">
					Fee Summary
				</div>

				<div class="preview-item">
					<span>Admission Fees</span>
					<span id="admissionPreview">₹0</span>
				</div>

				<div class="preview-item">
					<span>Monthly Fees</span>
					<span id="monthlyPreview">₹0</span>
				</div>

				<div class="preview-item">
					<span>Activity Fees</span>
					<span id="activityPreview">₹0</span>
				</div>

				<div class="preview-item">
					<span>Computer Fees</span>
					<span id="computerPreview">₹0</span>
				</div>

				<div class="total-box">
					<h2>Total</h2>
					<span id="totalDisplay">₹0</span>
				</div>

			</div>

		</div>

		<!-- RIGHT PANEL -->

		<div class="right-panel">

			<h2 class="form-heading">
				Edit Fee Structure
			</h2>

			<p class="form-subheading">
				Update fee details carefully for this class and session.
			</p>
		
			

			<div asp-validation-summary="ModelOnly"
				 class="alert alert-danger"
				 role="alert">
			</div>

			<form asp-action="Edit" method="post">

				<input type="hidden"
					   name="medium"
					   value="@ViewBag.Medium" />

				<input type="hidden"
					   asp-for="FeeId" />

	

				<div class="form-grid">
					<!-- SESSION -->

					<div class="form-group">

						<label>
							Session
						</label>

						@Html.DropDownList(
															"SessionId",
															ViewBag.SessionList as SelectList,
															"-- Select Session --",
															new
															{
																@class = "form-control",
																id = "sessionSelect"
															})

					</div>

					<!-- MEDIUM -->

					<div class="form-group">

						<label>
							Medium
						</label>

						@Html.DropDownList(
															"medium",
															ViewBag.MediumList as SelectList,
															"-- Select Medium --",
															new
															{
																@class = "form-control",
																id = "mediumSelect"
															})

					</div>

					<!-- CLASS -->

					<div class="form-group">

						<label>
							Class
						</label>

						<select asp-for="ClassId"
								id="classSelect"
								class="form-control">

							<option value="">
								-- Select Class --
							</option>

						</select>

					</div>
					<!-- ADMISSION -->

					<div class="form-group">

						<label asp-for="AdmissionFees"></label>

						<input asp-for="AdmissionFees"
							   class="form-control" />

						<span asp-validation-for="AdmissionFees"
							  class="text-danger">
						</span>

					</div>

					<!-- MONTHLY -->

					<div class="form-group">

						<label asp-for="MonthlyFees">
							Monthly Fees
						</label>

						<input asp-for="MonthlyFees"
							   class="form-control" />

						<small>
							Monthly fee × 12 months
						</small>

						<span asp-validation-for="MonthlyFees"
							  class="text-danger">
						</span>

					</div>

					<!-- ACTIVITY -->

					<div class="form-group">

						<label asp-for="OtherActivityFees">
							Other Activity Fees
						</label>

						<input asp-for="OtherActivityFees"
							   class="form-control" />

						<span asp-validation-for="OtherActivityFees"
							  class="text-danger">
						</span>

					</div>

					<!-- COMPUTER -->

					<div class="form-group">

						<label asp-for="ComputerFees">
							Computer Fees
						</label>

						<input asp-for="ComputerFees"
							   class="form-control" />

						<span asp-validation-for="ComputerFees"
							  class="text-danger">
						</span>

					</div>

				</div>

				

				<!-- BUTTONS -->

				<div class="button-area">

					<button type="submit"
							class="submit-btn">

						Update Structure

					</button>

					<a asp-action="Index"
					   asp-route-sessionId="@ViewBag.SessionId"
					   asp-route-medium="@ViewBag.Medium"
					   asp-route-classId="@ViewBag.ClassId"
					   class="cancel-btn">

						Cancel

					</a>

				</div>

			</form>

		</div>

	</div>

</div>

<partial name="_ValidationScriptsPartial" />

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

	$(document).ready(function () {

		let selectedClassId =
			'@Model.ClassId';

		let selectedSessionId =
			'@Model.SessionId';

		let selectedMedium =
			'@ViewBag.Medium';

		// AUTO LOAD CLASSES

		if (
			selectedSessionId &&
			selectedMedium
		) {

			loadClasses(
				selectedSessionId,
				selectedMedium,
				selectedClassId
			);
		}

		// SESSION CHANGE

		$('#sessionSelect').change(function () {

			let sessionId =
				$(this).val();

			let medium =
				$('#mediumSelect').val();

			resetClassDropdown();

			if (sessionId && medium) {

				loadClasses(
					sessionId,
					medium,
					null
				);
			}
		});

		// MEDIUM CHANGE

		$('#mediumSelect').change(function () {

			let medium =
				$(this).val();

			let sessionId =
				$('#sessionSelect').val();

			resetClassDropdown();

			if (sessionId && medium) {

				loadClasses(
					sessionId,
					medium,
					null
				);
			}
		});

		// LOAD CLASSES

		function loadClasses(
			sessionId,
			medium,
			selectedClassId
		) {

			$.ajax({

				url:
					'/FeesStructures/GetClassesByMedium',

				type: 'GET',

				data: {
					medium: medium,
					sessionId: sessionId
				},

				success: function (data) {

					let $class =
						$('#classSelect');

					$class.empty();

					$class.append(
						'<option value="">-- Select Class --</option>'
					);

					$.each(data, function (i, c) {

						let option =
							$('<option></option>')
								.attr('value', c.value)
								.text(c.text);

						if (
							selectedClassId &&
							c.value == selectedClassId
						) {

							option.attr(
								'selected',
								'selected'
							);
						}

						$class.append(option);
					});
				}
			});
		}

		// RESET CLASS

		function resetClassDropdown() {

			$('#classSelect')
				.empty()
				.append(
					'<option value="">-- Select Class --</option>'
				);
		}

		function calculateTotal() {

			let admission =
				parseFloat($('#AdmissionFees').val()) || 0;

			let monthly =
				parseFloat($('#MonthlyFees').val()) || 0;

			let other =
				parseFloat($('#OtherActivityFees').val()) || 0;

			let computer =
				parseFloat($('#ComputerFees').val()) || 0;

			let total =
				admission + (monthly * 12) + other + computer;

			$('#admissionPreview')
				.text('₹' + admission.toFixed(2));

			$('#monthlyPreview')
				.text('₹' + (monthly * 12).toFixed(2));

			$('#activityPreview')
				.text('₹' + other.toFixed(2));

			$('#computerPreview')
				.text('₹' + computer.toFixed(2));

			$('#totalDisplay')
				.text('₹' + total.toFixed(2));
		}

		$('#AdmissionFees').on('input', calculateTotal);

		$('#MonthlyFees').on('input', calculateTotal);

		$('#OtherActivityFees').on('input', calculateTotal);

		$('#ComputerFees').on('input', calculateTotal);

		calculateTotal();

	});

</script>