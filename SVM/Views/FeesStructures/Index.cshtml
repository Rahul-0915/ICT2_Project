@{
    ViewData["Title"] = "Fee Structures";
    var list = ViewBag.FeeStructures as List<SVM.Models.FeeStructure>;

    bool hasSearch =
     ViewBag.SelectedSessionId != null &&
     ViewBag.SelectedMedium != null &&
     ViewBag.SelectedClassId != null;
}

<link rel="stylesheet"
      href="/css/AdminSide_Css/Fees_Structure_display.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="/css/AdminSide_Css/SearchBar.css"
      asp-append-version="true" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="fee-page">

    <!-- TOP BAR -->
    <div class="top-bar">
        <form method="get" class="left-side" onsubmit="return validateSearch()">

            <!-- SESSION -->
            @Html.DropDownList(
                     "sessionId",
                     ViewBag.SessionList as SelectList,
                     "-- Select Session --",
                     new { @class = "search-box", id = "sessionSelect" })

            <!-- MEDIUM -->
            @Html.DropDownList(
                     "medium",
                     ViewBag.MediumList as SelectList,
                     "-- Select Medium --",
                     new { @class = "search-box", id = "mediumSelect" })

            <!-- CLASS -->
            <select name="classId" id="classSelect" class="search-box">
                <option value="">-- Select Class --</option>
            </select>

            <!-- SEARCH -->
            <button type="submit" class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
                Search
            </button>

            <!-- RESET -->
            <button type="button" class="reset-btn" onclick="resetFilters()">
                Reset
            </button>
        </form>

        <!-- CREATE -->
        <a asp-action="Create" class="add-btn">
            <i class="fa-solid fa-plus"></i>
        </a>
    </div>

    <!-- MESSAGE -->
    <h3 id="messageBox" class="no-data" style="text-align:center">
        Search to view class wise fee structures
    </h3>

    <!-- TABLE -->
    @if (list != null && list.Any())
    {
        <div id="feeTableSection" class="table-card">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Admission Fees</th>
                            <th>Monthly Fees</th>
                            <th>Activity Fees</th>
                            <th>Computer Fees</th>
                            <th>Total Amount</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fs in list)
                        {
                            <tr>
                                <td>@fs.AdmissionFees?.ToString("C")</td>
                                <td>@fs.MonthlyFees?.ToString("C")</td>
                                <td>@fs.OtherActivityFees?.ToString("C")</td>
                                <td>@fs.ComputerFees?.ToString("C")</td>
                                <td>@fs.TotalAmount?.ToString("C")</td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Edit"
                                           asp-route-id="@fs.FeeId"
                                           asp-route-sessionId="@ViewBag.SelectedSessionId"
                                           asp-route-medium="@ViewBag.SelectedMedium"
                                           asp-route-classId="@ViewBag.SelectedClassId"
                                           class="edit-btn">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details"
                                           asp-route-id="@fs.FeeId"
                                           class="view-btn">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a asp-action="Delete"
                                           asp-route-id="@fs.FeeId"
                                           asp-route-sessionId="@ViewBag.SelectedSessionId"
                                           asp-route-medium="@ViewBag.SelectedMedium"
                                           asp-route-classId="@ViewBag.SelectedClassId"
                                           class="delete-btn">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    const msg = document.getElementById("messageBox");
    msg.style.display = "block";
    msg.style.color = "#6b7280";

    @if (hasSearch)
    {
        if (list == null || !list.Any())
        {
            <text>
                msg.innerText = "No Data Found";
            msg.style.color = "red";
            </text>
        }
        else
        {
            <text>
                msg.style.display = "none";
            </text>
        }
    }

        // Get URL parameter
        function getParam(p) {
            return new URLSearchParams(window.location.search).get(p);
        }

    // Load classes based on session and medium
    function loadClasses(sessionId, medium, selectedClassId) {
        if (!sessionId || !medium) {
            resetClassDropdown();
            return;
        }

        $.ajax({
            url: '/FeesStructures/GetClassesByMedium',
            type: 'GET',
            data: { medium: medium, sessionId: sessionId },
            success: function (data) {
                let $class = $('#classSelect');
                $class.empty();
                $class.append('<option value="">-- Select Class --</option>');

                if (data && data.length > 0) {
                    $.each(data, function (i, c) {
                        let option = $('<option></option>')
                            .attr('value', c.value)
                            .text(c.text);

                        if (selectedClassId && c.value == selectedClassId) {
                            option.attr('selected', 'selected');
                        }
                        $class.append(option);
                    });
                } else {
                    $class.append('<option value="" disabled>No classes available</option>');
                }
            },
            error: function () {
                resetClassDropdown();
            }
        });
    }

    function resetClassDropdown() {
        $('#classSelect').empty().append('<option value="">-- Select Class --</option>');
    }

    function resetFilters() {
        // Reset dropdowns
        document.getElementById("sessionSelect").value = "";
        document.getElementById("mediumSelect").value = "";
        resetClassDropdown();

        // Hide table
        let table = document.getElementById("feeTableSection");
        if (table) {
            table.style.display = "none";
        }

        // Show message
        msg.style.display = "block";
        msg.style.color = "#6b7280";
        msg.innerText = "Search to view class wise fee structures";

        // Clear URL
        window.history.replaceState({}, document.title, window.location.pathname);
    }

    function validateSearch() {
        let session = document.getElementById("sessionSelect").value;
        let medium = document.getElementById("mediumSelect").value;
        let classId = document.getElementById("classSelect").value;

        if (session === "" || medium === "" || classId === "") {
            msg.style.display = "block";
            msg.style.color = "red";
            msg.innerText = "Please select Session, Medium and Class";
            return false;
        }
        return true;
    }

    $(document).ready(function () {

        let sessionId =
            $('#sessionSelect').val();

        let medium =
            $('#mediumSelect').val();

        let classId =
            '@ViewBag.SelectedClassId';

        // AUTO LOAD CLASSES
        if (sessionId && medium) {
            loadClasses(
                sessionId,
                medium,
                classId
            );
        }

        // SESSION CHANGE
        $('#sessionSelect').change(function () {

            let session =
                $(this).val();

            let medium =
                $('#mediumSelect').val();

            resetClassDropdown();

            if (session && medium) {

                loadClasses(
                    session,
                    medium,
                    null
                );
            }
        });

        // MEDIUM CHANGE
        $('#mediumSelect').change(function () {

            let medium =
                $(this).val();

            let session =
                $('#sessionSelect').val();

            resetClassDropdown();

            if (session && medium) {

                loadClasses(
                    session,
                    medium,
                    null
                );
            }
        });
    });


  
</script>