@{
	ViewData["Title"] = "Fee Structures";
	var list = ViewBag.FeeStructures as List<SVM.Models.FeeStructure>;

	bool hasSearch =
		ViewBag.SelectedSessionId != null ||
		ViewBag.SelectedMedium != null ||
		ViewBag.SelectedClassId != null;
}

<link rel="stylesheet"
	  href="/css/AdminSide_Css/Fees_Structure_display.css"
	  asp-append-version="true" />

<link rel="stylesheet"
	  href="/css/AdminSide_Css/SearchBar.css"
	  asp-append-version="true" />

<link rel="stylesheet"
	  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="fee-page">

	<!-- TOP BAR -->

	<div class="top-bar">

		<form method="get"
			  class="left-side"
			  onsubmit="return validateSearch()">

			<!-- SESSION -->
			@Html.DropDownList(
							"sessionId",
							ViewBag.SessionList as SelectList,
							"-- Select Session --",
							new
							{
								@class = "search-box",
								id = "sessionSelect"
							})

			<!-- MEDIUM -->
			@Html.DropDownList(
							"medium",
							ViewBag.MediumList as SelectList,
							"-- Select Medium --",
							new
							{
								@class = "search-box",
								id = "mediumSelect"
							})

			<!-- CLASS -->

			<select name="classId"
					id="classSelect"
					class="search-box">

				<option value="">Select Class</option>

			</select>

			<!-- SEARCH -->

			<button type="submit"
					class="search-btn">
				<i class="fa-solid fa-magnifying-glass"></i>

				Search

			</button>

			<!-- RESET -->

			
			<button type="button"
					class="reset-btn"
					onclick="resetFilters()">

				Reset

			</button>

		</form>

		<!-- CREATE -->

		<a asp-action="Create"
		   class="add-btn">

			<i class="fa-solid fa-plus"></i>

		</a>

	</div>

	<!-- TITLE -->



	<!-- MESSAGE -->

	<h3 id="messageBox"
		 class="no-data" style="text-align:center">

		Search to view class wise fee structures

	</h3>

	<!-- TABLE -->
	@if (list != null && list.Any())
	{
		<div id="feeTableSection"
			 class="table-card">

			<div class="table-responsive">

				<table class="table">

					<thead>

						<tr>

							<th>Admission Fees</th>
							<th>Monthly Fees</th>
							<th>Activity Fees</th>
							<th>Computer Fees</th>
							<th>Total Amount</th>
							<th>Actions</th>

						</tr>

					</thead>

					<tbody>

						@foreach (var fs in list)
						{
							<tr>

								<td>@fs.AdmissionFees?.ToString("C")</td>

								<td>@fs.MonthlyFees?.ToString("C")</td>

								<td>@fs.OtherActivityFees?.ToString("C")</td>

								<td>@fs.ComputerFees?.ToString("C")</td>

								<td>@fs.TotalAmount?.ToString("C")</td>

								<td>

									<div class="action-buttons">

										<!-- EDIT -->

										<a asp-action="Edit"
										   asp-route-id="@fs.FeeId"
										   asp-route-sessionId="@ViewBag.SelectedSessionId"
										   asp-route-medium="@ViewBag.SelectedMedium"
										   asp-route-classId="@ViewBag.SelectedClassId"
										   class="edit-btn">

											<i class="fa-solid fa-pen"></i>

										</a>

										<!-- DETAILS -->

										<a asp-action="Details"
										   asp-route-id="@fs.FeeId"
										   class="view-btn">

											<i class="fa-solid fa-eye"></i>

										</a>

										<!-- DELETE -->

										<a asp-action="Delete"
										   asp-route-id="@fs.FeeId"
										   asp-route-sessionId="@ViewBag.SelectedSessionId"
										   asp-route-medium="@ViewBag.SelectedMedium"
										   asp-route-classId="@ViewBag.SelectedClassId"
										   class="delete-btn">

											<i class="fa-solid fa-trash"></i>

										</a>

									</div>

								</td>

							</tr>
						}

					</tbody>

				</table>

			</div>

			<!-- PDF -->

			@* <a asp-action="DownloadPdf"
			   asp-route-sessionId="@ViewBag.SelectedSessionId"
			   asp-route-medium="@ViewBag.SelectedMedium"
			   asp-route-classId="@ViewBag.SelectedClassId"
			   class="pdf-btn">

				<i class="fa-solid fa-file-pdf"></i>
				Download PDF

			</a> *@

		</div>
	}

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

	// MESSAGE BOX

	const msg =
		document.getElementById("messageBox");

	// DEFAULT MESSAGE

	msg.style.display = "block";
	msg.style.color = "#6b7280";

	@if (hasSearch)
	{
		if (list == null || !list.Any())
		{
			<text>
				msg.innerText = "No Data Found";
			msg.style.color = "red";
			</text>
		}
		else
		{
			<text>
				msg.style.display = "none";
			</text>
		}
	}

		// SEARCH VALIDATION

		function validateSearch() {

			let session =
				document.getElementById("sessionSelect").value;

			let medium =
				document.getElementById("mediumSelect").value;

			let classId =
				document.getElementById("classSelect").value;

			if (session === "" ||
				medium === "" ||
				classId === "") {

				msg.style.display = "block";
				msg.style.color = "red";
				msg.innerText =
					"Please select Session, Medium and Class";

				return false;
			}

			return true;
		}

	// URL PARAM

	function getParam(p) {

		return new URLSearchParams(window.location.search)
			.get(p);
	}

	$(document).ready(function () {

		let session = getParam('sessionId');
		let medium = getParam('medium');
		let classId = getParam('classId');

		if (session)
			$('#sessionSelect').val(session);

		if (medium)
			$('#mediumSelect').val(medium);

		// LOAD CLASS

		if (medium) {

			$.get('/FeesStructures/GetClassesByMedium',
				{ medium: medium },

				function (data) {

					let $class = $('#classSelect');

					$class.empty();

					$class.append(
						'<option value="">Select Class</option>'
					);

					$.each(data, function (i, c) {

						let opt =
							$('<option>')
								.val(c.value)
								.text(c.text);

						if (classId &&
							c.value == classId) {

							opt.prop('selected', true);
						}

						$class.append(opt);
					});
				});
		}

		// CHANGE MEDIUM

		$('#mediumSelect').change(function () {

			let med = $(this).val();

			if (med) {

				$.get('/FeesStructures/GetClassesByMedium',
					{ medium: med },

					function (data) {

						let $class = $('#classSelect');

						$class.empty();

						$class.append(
							'<option value="">Select Class</option>'
						);

						$.each(data, function (i, c) {

							$class.append(

								$('<option>')
									.val(c.value)
									.text(c.text)

							);
						});
					});
			}
			else {

				$('#classSelect')
					.empty()
					.append('<option value="">Select Class</option>');
			}
		});
	});

	function resetFilters() {

		// dropdown reset

		document.getElementById("sessionSelect").value = "";
		document.getElementById("mediumSelect").value = "";

		$('#classSelect')
			.empty()
			.append('<option value="">Select Class</option>');

		// table hide

		let table =
			document.getElementById("feeTableSection");

		if (table) {
			table.style.display = "none";
		}

		// message show

		msg.style.display = "block";
		msg.style.color = "#6b7280";
		msg.innerText =
			"Search to view class wise fee structures";

		// url clear

		window.history.replaceState(
			{},
			document.title,
			window.location.pathname
		);
	}

</script>