@model SVM.Models.FeeStructure

@{
    ViewData["Title"] = "Delete";
}
<link rel="stylesheet" href="~/css/Delete.css" asp-append-version="true" />

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>FeeStructure</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Session</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(ViewBag.SessionName) && ViewBag.SessionName != "Not Found")
            {
                @ViewBag.SessionName
            }
            else
            {
                <span class="text-danger">Session name not available (ID: @Model.SessionId)</span>
            }
        </dd>

        <dt class="col-sm-2">Class</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(ViewBag.ClassName) && ViewBag.ClassName != "Not Found")
            {
                @ViewBag.ClassName
            }
            else
            {
                <span class="text-danger">Class name not available (ID: @Model.ClassId)</span>
            }
        </dd>

        <dt class="col-sm-2">Admission Fees</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AdmissionFees)</dd>

        <dt class="col-sm-2">Monthly Fees</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.MonthlyFees)</dd>

        <dt class="col-sm-2">Other Activity Fees</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OtherActivityFees)</dd>

        <dt class="col-sm-2">Computer Fees</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ComputerFees)</dd>

        <dt class="col-sm-2">Total Amount</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.TotalAmount)</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="FeeId" />
        <input type="hidden" name="sessionId" value="@ViewBag.SessionId" />
        <input type="hidden" name="medium" value="@ViewBag.Medium" />
        <input type="hidden" name="classId" value="@ViewBag.ClassId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <!-- ✅ Cancel link now preserves filters -->
        <a asp-action="Index"
           asp-route-sessionId="@ViewBag.SessionId"
           asp-route-medium="@ViewBag.Medium"
           asp-route-classId="@ViewBag.ClassId"
           class="btn btn-secondary">Cancel</a>
    </form>
</div>